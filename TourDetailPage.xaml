<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelApp.TourDetailPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F6F6F8">

    <Grid RowDefinitions="300,*">
        <Grid Grid.Row="0">
            <Image Source="{Binding Tour.ImageUrl}" Aspect="AspectFill" />

            <Grid Padding="18,52,18,0" ColumnDefinitions="56,*,56" VerticalOptions="Start">
                <Border BackgroundColor="#E31667" StrokeThickness="0" WidthRequest="56" HeightRequest="56" StrokeShape="RoundRectangle 28">
                    <Button Text="←"
                            Command="{Binding BackCommand}"
                            BackgroundColor="Transparent"
                            TextColor="White"
                            FontSize="28" />
                </Border>

                <Border Grid.Column="2" BackgroundColor="White" StrokeThickness="0" WidthRequest="56" HeightRequest="56" StrokeShape="RoundRectangle 28">
                    <Label Text="▯" TextColor="#C2185B" FontSize="24" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="1" BackgroundColor="#F6F6F8" StrokeThickness="0" StrokeShape="RoundRectangle 0" Padding="18,18,18,12">
            <ScrollView>
                <VerticalStackLayout Spacing="12">
                    <Label Text="{Binding Tour.Title}" FontSize="24" FontAttributes="Bold" TextColor="#2C2D33" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="{Binding Tour.Location}" FontSize="16" TextColor="#8A8B92" />
                        <Label Grid.Column="1" Text="{Binding Tour.Price}" FontSize="22" TextColor="#D31963" FontAttributes="Bold" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Border Stroke="#CFD4D9" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="10,8">
                            <Label Text="{Binding Tour.Subtitle, StringFormat='🕴  {0}'}" FontSize="14" TextColor="#1C6272" />
                        </Border>
                        <Border Grid.Column="1" Stroke="#CFD4D9" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="10,8">
                            <Label Text="{Binding Tour.Distance, StringFormat='⇄  {0}'}" FontSize="14" TextColor="#1C6272" />
                        </Border>
                        <Border Grid.Column="2" Stroke="#CFD4D9" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="10,8">
                            <Label Text="{Binding Tour.Duration, StringFormat='◷  {0}'}" FontSize="14" TextColor="#1C6272" />
                        </Border>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#E7E8EC" Margin="0,2" />

                    <Grid ColumnDefinitions="60,60,*,120" ColumnSpacing="10">
                        <Border Stroke="#E3E4E8" StrokeThickness="1" StrokeShape="RoundRectangle 30" BackgroundColor="White" WidthRequest="60" HeightRequest="60">
                            <Label Text="⤓" TextColor="#D31963" FontSize="30" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Border>
                        <Border Grid.Column="1" Stroke="#E3E4E8" StrokeThickness="1" StrokeShape="RoundRectangle 30" BackgroundColor="White" WidthRequest="60" HeightRequest="60">
                            <Label Text="⇪" TextColor="#D31963" FontSize="28" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Border>
                        <Border Grid.Column="2" Stroke="#1C6272" StrokeThickness="2" StrokeShape="RoundRectangle 30" Padding="18,0" HeightRequest="60">
                            <Label Text="Preview" TextColor="#1C6272" FontSize="18" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Border>
                        <Border Grid.Column="3" Stroke="#D31963" StrokeThickness="2" StrokeShape="RoundRectangle 30" Padding="16,0" HeightRequest="60">
                            <Label Text="en  ▾" TextColor="#D31963" FontSize="18" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*" Margin="0,4,0,0">
                        <Label Text="Description" TextColor="#D31963" FontSize="16" HorizontalTextAlignment="Center" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="Stories (20)" TextColor="#94959B" FontSize="16" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="2" Text="Reviews" TextColor="#94959B" FontSize="16" HorizontalTextAlignment="Center" />
                    </Grid>
                    <BoxView HeightRequest="2" WidthRequest="122" Color="#D31963" HorizontalOptions="Start" />
                    <BoxView HeightRequest="1" Color="#E7E8EC" Margin="0,-10,0,0" />

                    <Label FontSize="16">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Provided by " TextColor="#2B2D33" />
                                <Span Text="{Binding ProviderName}" TextColor="#1C6272" TextDecorations="Underline" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                    <Label Text="{Binding Description}" FontSize="16" TextColor="#2B2D33" LineBreakMode="WordWrap" />

                    <Label Text="{Binding Credit}" FontSize="14" TextColor="#2D89C8" TextDecorations="Underline" LineBreakMode="WordWrap" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="14" Margin="0,10,0,10">
                        <Border Stroke="#D31963" StrokeThickness="2" StrokeShape="RoundRectangle 28" HeightRequest="58">
                            <Label Text="Get Tickets" TextColor="#D31963" FontSize="20" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontAttributes="Bold" />
                        </Border>
                        <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="#E31667" StrokeShape="RoundRectangle 28" HeightRequest="58">
                            <Label Text="Buy Tour" TextColor="White" FontSize="20" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontAttributes="Bold" />
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </ScrollView>
        </Border>
    </Grid>
</ContentPage>
