<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
             x:Class="TravelApp.ExplorePage"
             BackgroundColor="#F2F2F5"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="120,*,84">

        <!-- Header -->
        <Grid Grid.Row="0">
            <Image Source="https://images.unsplash.com/photo-1480714378408-67cf0d13bc1f?w=1200&amp;h=500&amp;fit=crop"
                   Aspect="AspectFill" />
            <BoxView Color="#007A97" Opacity="0.86" />

            <Grid Padding="14,48,14,14" ColumnDefinitions="36,*,36" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Text="☰"
                        Command="{Binding ToggleMenuCommand}"
                        TextColor="White"
                        FontSize="24"
                        BackgroundColor="Transparent"
                        Padding="0" />

                <Border Grid.Column="1"
                        Stroke="#E84C7F"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 22"
                        BackgroundColor="White"
                        Padding="14,0"
                        HeightRequest="48"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenSearchCommand}" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,46">
                        <Label Text="Explore destinations"
                               TextColor="#5D6D79"
                               FontSize="14"
                               VerticalTextAlignment="Center" />

                        <Border Grid.Column="1"
                                StrokeThickness="0"
                                BackgroundColor="#D61B63"
                                StrokeShape="RoundRectangle 23"
                                WidthRequest="40"
                                HeightRequest="40"
                                HorizontalOptions="Center"
                                VerticalOptions="Center">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenSearchCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="⌕"
                                   TextColor="White"
                                   FontSize="20"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Border>
                    </Grid>
                </Border>

                <Label Grid.Column="2"
                       Text="◉"
                       TextColor="White"
                       FontSize="20"
                       VerticalTextAlignment="Center"
                       HorizontalTextAlignment="Center" />
            </Grid>
        </Grid>

        <!-- Body -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="14,14,14,8" Spacing="14">

                <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                    <Label Text="Around me"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#121212" />
                    <Label Grid.Column="1"
                           Text="Map view"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#C2185B"
                           VerticalTextAlignment="Center" />
                </Grid>

                <Border StrokeThickness="0"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 16"
                        HeightRequest="230">
                    <maps:Map x:Name="ExploreMap"
                              MapType="Street"
                              IsTrafficEnabled="False"
                              IsShowingUser="False" />
                </Border>

                <Border x:Name="AudioStatusBorder"
                        IsVisible="False"
                        StrokeThickness="0"
                        BackgroundColor="#1F8A70"
                        StrokeShape="RoundRectangle 14"
                        Padding="12,10">
                    <VerticalStackLayout Spacing="2">
                        <Label x:Name="AudioStatusTextLabel"
                               Text="Đang phát audio"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="White" />
                        <Label x:Name="AudioPoiTitleLabel"
                               Text=""
                               FontSize="13"
                               TextColor="#E6FFF7"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8" VerticalOptions="Center">
                    <Label Text="For you"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#111111" />
                    <Label Grid.Column="1"
                           Text="☷"
                           FontSize="16"
                           TextColor="#7E7E89"
                           VerticalTextAlignment="Center" />
                    <Label Grid.Column="3"
                           Text="See more"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#C2185B"
                           VerticalTextAlignment="Center" />
                </Grid>

                <CollectionView x:Name="ForYouCollection" ItemsSource="{Binding ForYouItems}" HeightRequest="290" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border WidthRequest="312"
                                    Stroke="#E7E7EA"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 24"
                                    BackgroundColor="White">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenTourDetailCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid RowDefinitions="165,*">
                                    <Grid Grid.Row="0">
                                        <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />

                                        <Border Margin="0,12,12,0"
                                                HorizontalOptions="End"
                                                VerticalOptions="Start"
                                                StrokeThickness="0"
                                                BackgroundColor="White"
                                                StrokeShape="RoundRectangle 20"
                                                WidthRequest="40"
                                                HeightRequest="40">
                                            <Label Text="↥"
                                                   TextColor="#C2185B"
                                                   FontSize="20"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center" />
                                        </Border>

                                        <Border Margin="12,0,0,12"
                                                VerticalOptions="End"
                                                HorizontalOptions="Start"
                                                StrokeThickness="0"
                                                BackgroundColor="White"
                                                StrokeShape="RoundRectangle 16"
                                                Padding="12,6">
                                            <Label Text="~ m  |  ~ min"
                                                   FontSize="12"
                                                   TextColor="#7A7A84" />
                                        </Border>
                                    </Grid>

                                    <Grid Grid.Row="1"
                                          Padding="14,10,14,12"
                                          RowDefinitions="Auto,Auto,Auto"
                                          ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold" />
                                        <Label Grid.Column="1" Text="{Binding Price}" FontSize="16" FontAttributes="Bold" TextColor="#C2185B" />

                                        <Label Grid.Row="1" Text="{Binding Subtitle}" FontSize="13" TextColor="#7B7B85" />
                                        <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="4" HorizontalOptions="End">
                                            <Label Text="★" TextColor="#F6A928" FontSize="14" />
                                            <Label Text="{Binding Rating}" FontSize="14" TextColor="#777781" />
                                            <Label Text="{Binding ReviewCount, StringFormat='({0})'}" FontSize="13" TextColor="#A0A0A9" />
                                        </HorizontalStackLayout>

                                        <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="2" Spacing="5">
                                            <Label Text="◉" TextColor="#3F7DFF" FontSize="12" />
                                            <Label Text="{Binding Location}" FontSize="13" TextColor="#7A7A84" LineBreakMode="TailTruncation" />
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="Editor&apos;s choice"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#111111" />

                <CollectionView x:Name="EditorsChoiceCollection" ItemsSource="{Binding EditorsChoiceItems}" HeightRequest="260" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border WidthRequest="312"
                                    Stroke="#E7E7EA"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 24"
                                    BackgroundColor="White">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenTourDetailCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid RowDefinitions="165,*">
                                    <Grid Grid.Row="0">
                                        <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                        <Border Margin="0,12,12,0"
                                                HorizontalOptions="End"
                                                VerticalOptions="Start"
                                                StrokeThickness="0"
                                                BackgroundColor="White"
                                                StrokeShape="RoundRectangle 20"
                                                WidthRequest="40"
                                                HeightRequest="40">
                                            <Label Text="↥"
                                                   TextColor="#C2185B"
                                                   FontSize="20"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center" />
                                        </Border>
                                    </Grid>

                                    <Grid Grid.Row="1" Padding="14,10,14,12" RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold" />
                                        <Label Grid.Column="1" Text="{Binding Price}" FontSize="16" FontAttributes="Bold" TextColor="#C2185B" />
                                        <Label Grid.Row="1" Text="{Binding Subtitle}" FontSize="13" TextColor="#7B7B85" />
                                        <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="2" Spacing="5">
                                            <Label Text="◉" TextColor="#3F7DFF" FontSize="12" />
                                            <Label Text="{Binding Location}" FontSize="13" TextColor="#7A7A84" LineBreakMode="TailTruncation" />
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <BoxView HeightRequest="6" Color="Transparent" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Nav -->
        <Border Grid.Row="2"
                StrokeThickness="0"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 26,26,0,0"
                Padding="10,8,10,14">
            <Grid ColumnDefinitions="*,*,*,*,*">
                <VerticalStackLayout Spacing="1" HorizontalOptions="Center">
                    <Label Text="◉" FontSize="20" HorizontalTextAlignment="Center" />
                    <Label Text="Explore" FontSize="12" TextColor="#C2185B" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" Spacing="1" HorizontalOptions="Center">
                    <Label Text="◎" FontSize="20" HorizontalTextAlignment="Center" />
                    <Label Text="Discover" FontSize="12" TextColor="#8C8C97" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2" Spacing="1" HorizontalOptions="Center">
                    <Label Text="▦" FontSize="20" HorizontalTextAlignment="Center" />
                    <Label Text="My Tours" FontSize="12" TextColor="#8C8C97" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="3" Spacing="1" HorizontalOptions="Center">
                    <Label Text="◌" FontSize="20" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="4" Spacing="1" HorizontalOptions="Center">
                    <Label Text="≡" FontSize="26" HorizontalTextAlignment="Center" TextColor="#8C8C97" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- Drawer Overlay -->
        <Grid Grid.RowSpan="3"
              IsVisible="{Binding IsMenuOpen}"
              InputTransparent="False"
              ColumnDefinitions="300,*">

            <Grid Grid.Column="0" BackgroundColor="#E31667">
                <ScrollView>
                    <VerticalStackLayout Padding="24,46,18,20" Spacing="18">
                        <Button Text="✕"
                                Command="{Binding CloseMenuCommand}"
                                TextColor="White"
                                FontSize="28"
                                HorizontalOptions="Start"
                                BackgroundColor="Transparent"
                                Padding="0" />

                        <Label Text="{Binding AuthMenuText, StringFormat='⇄  {0}'}"
                               TextColor="White"
                               FontSize="18">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SignInOutCommand}" />
                            </Label.GestureRecognizers>
                        </Label>

                        <Label Text="◉  My Profile"
                               TextColor="White"
                               FontSize="18">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenProfileCommand}" />
                            </Label.GestureRecognizers>
                        </Label>

                        <BoxView HeightRequest="1" Color="#F5A0C2" Margin="0,4" />

                        <Label Text="◍  Purchases"
                               TextColor="White"
                               FontSize="18" />

                        <Label Text="◷  History"
                               TextColor="White"
                               FontSize="18" />

                        <Label Text="▮  Bookmarks"
                               TextColor="White"
                               FontSize="18" />

                        <Label Text="🛠  Debug Console"
                               TextColor="White"
                               FontSize="18">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenDebugConsoleCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>

            <Grid Grid.Column="1" BackgroundColor="#88000000">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseMenuCommand}" />
                </Grid.GestureRecognizers>
            </Grid>

        </Grid>

    </Grid>

</ContentPage>



