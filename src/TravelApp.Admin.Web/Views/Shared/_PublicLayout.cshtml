<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - TravelApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/html5-qrcode" type="text/javascript"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <style>
        :root { 
            --accent: #E31667; 
            --bg-dark: #000000; 
            --card-bg: #161A21; 
            --text-muted: #8E94A4; 
            --nav-bg: rgba(22, 26, 33, 0.85);
        }
        body { 
            background-color: var(--bg-dark); 
            color: #FFFFFF; 
            font-family: 'Inter', -apple-system, sans-serif; 
            padding-bottom: 100px; 
            overflow-x: hidden; 
        }
        .bottom-nav {
            position: fixed; bottom: 0; left: 0; right: 0;
            background: rgba(22, 26, 33, 0.9);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border-top: 1px solid rgba(255,255,255,0.1);
            display: flex; justify-content: space-around;
            padding: 15px 0 32px 0;
            z-index: 1000;
            border-radius: 35px 35px 0 0;
            box-shadow: 0 -10px 30px rgba(0,0,0,0.5);
        }
        .nav-item { color: var(--text-muted); text-decoration: none; text-align: center; font-size: 11px; font-weight: 600; flex: 1; }
        .nav-item.active { color: var(--accent); }
        .nav-item i { font-size: 24px; display: block; margin-bottom: 2px; }
        .poi-card { 
            background: var(--card-bg); 
            border-radius: 32px; 
            overflow: hidden; 
            border: 1px solid rgba(255,255,255,0.05); 
            margin-bottom: 28px; 
            box-shadow: 0 15px 35px rgba(0,0,0,0.4); 
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
        }
        .poi-card:active { transform: scale(0.98); }
        .poi-card img { height: 260px; object-fit: cover; width: 100%; }
        .badge-category { background: #E31667; border-radius: 12px; padding: 4px 10px; font-size: 10px; font-weight: 700; text-transform: uppercase; }
        .accent-color { color: #E31667; }
        .audio-player-sticky { position: fixed; bottom: 95px; left: 16px; right: 16px; background: var(--accent); border-radius: 20px; padding: 14px 20px; display: none; align-items: center; gap: 14px; box-shadow: 0 8px 24px rgba(227, 22, 103, 0.5); z-index: 999; animation: slideUp 0.3s ease-out; }
        @@keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
        .section-title { font-size: 28px; font-weight: 800; letter-spacing: -0.5px; }
        .category-chip { background: #1C2129; color: #FFFFFF; border-radius: 20px; padding: 8px 16px; font-size: 13px; font-weight: 600; white-space: nowrap; text-decoration: none; border: 1px solid rgba(255,255,255,0.1); }
        .category-chip.active { background: var(--accent); border-color: var(--accent); }
    </style>
</head>
<body>
    <main role="main">
        @RenderBody()
    </main>

    <div id="miniPlayer" class="audio-player-sticky">
        <div class="flex-grow-1 overflow-hidden">
            <div class="fw-bold small text-truncate" id="miniPlayerTitle">Đang phát...</div>
            <div class="small" style="font-size: 10px; opacity: 0.8;">Audio Guide Mode</div>
        </div>
        <button class="btn btn-link text-white p-0" onclick="toggleAudio()"><i id="miniPlayIcon" class="bi bi-pause-circle-fill fs-2"></i></button>
    </div>

    <nav class="bottom-nav">
        <a href="/Public" class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")"><i class="bi bi-compass-fill"></i>Khám phá</a>
        <a href="/Public/Scanner" class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Scanner" ? "active" : "")"><i class="bi bi-qr-code-scan"></i>Quét mã</a>
        <a href="#" class="nav-item"><i class="bi bi-collection-play-fill"></i>Thư viện</a>
        <a href="#" class="nav-item"><i class="bi bi-person-circle"></i>Hồ sơ</a>
    </nav>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        // Service Worker registration for PWA
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/service-worker.js');
        }
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>