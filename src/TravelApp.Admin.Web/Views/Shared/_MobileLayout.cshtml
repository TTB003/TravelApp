@using TravelApp.Admin.Web.Helpers
@using Microsoft.AspNetCore.Authentication
<!DOCTYPE html>
<html lang="vi">
@{
    var currentLang = Context.Request.Cookies["SelectedLanguage"] ?? "vi";
    
    // Lấy thông tin xác thực từ scheme Public
    var authResult = await Context.AuthenticateAsync("PublicAuthScheme");
    bool isLoggedIn = authResult.Succeeded;
    
    // Lấy thông tin từ Identity của PublicAuthScheme để đảm bảo không lấy lộn Admin
    var userName = authResult.Principal?.Identity?.Name;
    if (string.IsNullOrEmpty(userName)) {
        userName = authResult.Principal?.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Name)?.Value ?? "Khách";
    }

    var userEmail = authResult.Principal?.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value ?? "";
}
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>TravelApp Mobile Web</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root {
            --mobile-pink: #e91e63;
            --mobile-bg: #f8f9fa;
            --mobile-teal: #006080;
        }

        body {
            background-color: #333;
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        /* Khung giả lập điện thoại */
        .mobile-container {
            width: 100%;
            max-width: 414px;
            height: 100vh;
            max-height: 896px;
            background-color: var(--mobile-bg);
            position: relative;
            overflow: hidden;
            box-shadow: 0 0 50px rgba(0,0,0,0.5);
            display: flex;
            flex-direction: column;
        }

        @@media (min-width: 576px) {
            .mobile-container {
                border-radius: 30px;
                margin: 20px;
                height: calc(100vh - 40px);
            }
        }

        /* Sidebar (Drawer) giống 1.png */
        .mobile-drawer {
            position: absolute;
            top: 0;
            left: -100%;
            width: 80%;
            height: 100%;
            background-color: var(--mobile-pink);
            z-index: 1050;
            transition: left 0.3s ease;
            color: white;
            padding: 30px 24px;
            overflow-y: auto;
        }

        .mobile-drawer.open { left: 0; }

        .drawer-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 1040;
            display: none;
        }
        .drawer-overlay.active { display: block; }

        .drawer-item {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 12px 0;
            font-size: 1.1rem;
            cursor: pointer;
            text-decoration: none;
            color: white;
            font-weight: 500;
        }

        .drawer-item:hover {
            color: white;
            opacity: 0.8;
        }

        .drawer-icon {
            width: 40px; height: 40px;
            background: rgba(255,255,255,0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .drawer-close-container {
            display: flex;
            justify-content: center;
            margin-bottom: 40px;
        }

        .drawer-user-info {
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        /* Bottom Nav giống 2.png, 5.png */
        .bottom-nav {
            height: 70px;
            background: white;
            display: flex;
            justify-content: space-around;
            align-items: center;
            border-top: 1px solid #eee;
            padding-bottom: env(safe-area-inset-bottom);
            z-index: 1000;
        }

        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            color: #ccc;
            text-decoration: none;
            font-size: 0.7rem;
        }

        .nav-item.active { color: var(--mobile-pink); }
        .nav-item i { font-size: 1.5rem; }
        .nav-btn-circle {
            width: 50px; height: 50px;
            border-radius: 50%;
            background: #f0f0f0;
            display: flex; align-items: center; justify-content: center;
        }
        .active .nav-btn-circle { background: var(--mobile-pink); color: white; }

        .content-scroll {
            flex: 1;
            overflow-y: auto;
            scrollbar-width: none;
        }
        .content-scroll::-webkit-scrollbar { display: none; }
    </style>
</head>
<body>
    <div class="mobile-container">
        @Html.AntiForgeryToken()
        <div class="drawer-overlay" id="drawerOverlay"></div>
        <div class="mobile-drawer" id="mobileDrawer">
            <!-- Nút đóng dạng hình tròn lớn nằm giữa giống 1.png -->
            <div class="drawer-close-container">
                <div class="drawer-icon" style="width: 56px; height: 56px; border-radius: 28px; cursor: pointer;" onclick="toggleDrawer()">
                    <i class="bi bi-x-lg fs-4"></i>
                </div>
            </div>

            

            <div class="drawer-menu-items">
            @if (!isLoggedIn)
            {
                <a href="/Public/Login" class="drawer-item">
                    <div class="drawer-icon"><i class="bi bi-arrow-right-short fs-3"></i></div> 
                    @WebLocalizationHelper.Get("Login", currentLang)
                </a>
            }

            <a href="@Url.Action("Profile", "Public", new { area = "" })" class="drawer-item">
                <div class="drawer-icon"><i class="bi bi-person-circle"></i></div> 
                @(isLoggedIn ? $"{WebLocalizationHelper.Get("Hi", currentLang)} {userName}" : WebLocalizationHelper.Get("Hi", currentLang))
            </a>
            
            <div style="height: 1px; background: rgba(255,255,255,0.15); margin: 15px 0;"></div>

            <a href="#" class="drawer-item"><div class="drawer-icon"><i class="bi bi-music-note-beamed"></i></div> @WebLocalizationHelper.Get("Purchases", currentLang)</a>
            <a href="#" class="drawer-item"><div class="drawer-icon"><i class="bi bi-clock-history"></i></div> @WebLocalizationHelper.Get("History", currentLang)</a>
            <a href="#" class="drawer-item"><div class="drawer-icon"><i class="bi bi-bookmark"></i></div> @WebLocalizationHelper.Get("Bookmarks", currentLang)</a>
            <a href="#" class="drawer-item"><div class="drawer-icon"><i class="bi bi-terminal"></i></div> @WebLocalizationHelper.Get("Debug", currentLang)</a>

            @if (isLoggedIn)
            {
                <a href="javascript:logout()" class="drawer-item mt-2">
                    <div class="drawer-icon"><i class="bi bi-box-arrow-right"></i></div> 
                    @WebLocalizationHelper.Get("Logout", currentLang)
                </a>
            }
        </div>
        </div>

        @RenderBody()

        @await RenderSectionAsync("Scripts", required: false)
    </div>
    <script>
        function toggleDrawer() {
            document.getElementById('mobileDrawer').classList.toggle('open');
            document.getElementById('drawerOverlay').classList.toggle('active');
        }
        document.getElementById('drawerOverlay').onclick = toggleDrawer;

        async function logout() {
            localStorage.removeItem('public_login_success');
            
            // Chuyển hướng đến action Logout trên server để thực hiện SignOutAsync
            // Điều này đảm bảo cookie HttpOnly được xóa sạch sẽ
            window.location.href = '/Public/Logout';
        }
    </script>
</body>
</html>