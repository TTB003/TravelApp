@model TravelApp.Admin.Web.Models.Auth.LoginViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Đăng nhập";
}

<div class="auth-shell">
    <div class="auth-card shadow-lg">
        <div class="text-center mb-4">
            <div class="auth-logo mb-3">🍜</div>
            <h1 class="h3 fw-bold mb-1">TravelApp Admin</h1>
            <p class="text-muted mb-0">CMS Phố Ẩm Thực Việt</p>
        </div>

        <form id="adminLoginForm" class="vstack gap-3">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

            <div>
                <label asp-for="UserName" class="form-label">Tài khoản</label>
                <input asp-for="UserName" id="userName" class="form-control form-control-lg auth-input" placeholder="admin" />
                <span asp-validation-for="UserName" class="text-danger small"></span>
            </div>

            <div>
                <label asp-for="Password" class="form-label">Mật khẩu</label>
                <input asp-for="Password" id="password" type="password" class="form-control form-control-lg auth-input" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <button type="button" onclick="handleAdminLogin()" class="btn btn-primary btn-lg w-100 auth-button">Đăng nhập</button>
        </form>
    </div>
</div>

<script>
    async function handleAdminLogin() {
        const email = document.getElementById('userName').value;
        const pwd = document.getElementById('password').value;
        const returnUrl = document.getElementById('ReturnUrl').value || '/admin';

        if (!email || !pwd) return;

        try {
            const response = await fetch('/Auth/Login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({
                    'UserName': email,
                    'Password': pwd,
                    'RememberMe': 'true',
                    '__RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                })
            });

            if (response.ok) {
                // Đồng bộ AuthToken cho Mobile Layout
                document.cookie = "AuthToken=authenticated; path=/";
                window.location.href = returnUrl;
            } else {
                alert("Đăng nhập thất bại. Vui lòng kiểm tra lại.");
            }
        } catch (e) {
            alert("Lỗi kết nối server.");
        }
    }
</script>
