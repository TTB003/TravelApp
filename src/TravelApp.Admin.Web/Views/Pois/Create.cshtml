@model TravelApp.Admin.Web.Models.Pois.PoiEditorViewModel

@{
    ViewData["Title"] = "Tạo POI";
}

<div class="dashboard-grid">
    <div class="section-header">
        <div>
            <h1 class="section-title">Tạo POI mới</h1>
            <p class="section-subtitle">POI mới sẽ xuất hiện ngay trong dropdown của Tour.</p>
        </div>
        <div class="section-actions">
            <span class="soft-badge">POI • Create</span>
        </div>
    </div>

    <form asp-action="Create" method="post" class="content-grid" data-live-preview-form>
        <div class="d-grid gap-4">
            <div class="admin-card p-4">
                <div class="section-header mb-3">
                    <div>
                        <h2 class="section-title">Thông tin cơ bản</h2>
                        <p class="section-subtitle">Tên, mô tả và ngôn ngữ hiển thị.</p>
                    </div>
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Title" class="form-label">Title</label>
                        <input asp-for="Title" class="form-control" data-live-preview-input="Title" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Subtitle" class="form-label">Subtitle</label>
                        <input asp-for="Subtitle" class="form-control" data-live-preview-input="Subtitle" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" rows="4" class="form-control"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Category" class="form-label">Category</label>
                        <input asp-for="Category" class="form-control" data-live-preview-input="Category" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="PrimaryLanguage" class="form-label">Primary language</label>
                        <select asp-for="PrimaryLanguage" asp-items="Model.LanguageOptions" class="form-select" data-live-preview-input="PrimaryLanguage"></select>
                    </div>
                </div>
            </div>

            <div class="admin-card p-4">
                <div class="section-header mb-3">
                    <div>
                        <h2 class="section-title">Vị trí & hiển thị</h2>
                        <p class="section-subtitle">Dùng cho bản đồ, geofence và ảnh đại diện.</p>
                    </div>
                </div>
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="Location" class="form-label">Location</label>
                        <input asp-for="Location" class="form-control" data-live-preview-input="Location" />
                    </div>
                    <div class="col-12">
                        <label asp-for="ImageUrl" class="form-label">Image URL</label>
                        <input asp-for="ImageUrl" class="form-control" data-live-preview-input="ImageUrl" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Latitude" class="form-label">Latitude</label>
                        <input asp-for="Latitude" class="form-control" data-live-preview-input="Latitude" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Longitude" class="form-label">Longitude</label>
                        <input asp-for="Longitude" class="form-control" data-live-preview-input="Longitude" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="GeofenceRadiusMeters" class="form-label">Geofence radius</label>
                        <input asp-for="GeofenceRadiusMeters" class="form-control" data-live-preview-input="GeofenceRadiusMeters" />
                    </div>
                </div>
            </div>

            <div class="admin-card p-4">
                <div class="section-header mb-3">
                    <div>
                        <h2 class="section-title">Speech</h2>
                        <p class="section-subtitle">Nội dung đọc tự động và mã ngôn ngữ.</p>
                    </div>
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="SpeechTextLanguageCode" class="form-label">Speech text language</label>
                        <select asp-for="SpeechTextLanguageCode" asp-items="Model.LanguageOptions" class="form-select" data-live-preview-input="SpeechTextLanguageCode" data-speech-text-language-select="true"></select>
                    </div>
                    <div class="col-12">
                        <label asp-for="SpeechText" class="form-label">Speech text</label>
                        <textarea asp-for="SpeechText" rows="3" class="form-control" data-live-preview-input="SpeechText" data-speech-text-input="true"></textarea>
                    </div>
                </div>
            </div>

            <div class="admin-card p-4 mb-4">
                <div class="section-header mb-3">
                    <div>
                        <h2 class="section-title">Localizations</h2>
                        <p class="section-subtitle">Sửa tiêu đề, mô tả và subtitle theo từng ngôn ngữ.</p>
                    </div>
                    <button type="button" class="btn btn-outline-primary btn-sm" data-add-row data-target="poi-localization-rows" data-prefix="Localizations">+ Add row</button>
                </div>
                <div id="poi-localization-rows" data-next-index="@Model.Localizations.Count">
                    @for (var i = 0; i < Model.Localizations.Count; i++)
                    {
                        <div class="row g-2 mb-3" data-repeat-row data-repeat-group="Localizations">
                            <div class="col-md-2"><select asp-for="Localizations[@i].LanguageCode" asp-items="Model.LanguageOptions" class="form-select"></select></div>
                            <div class="col-md-3"><input asp-for="Localizations[@i].Title" class="form-control" placeholder="Title" /></div>
                            <div class="col-md-3"><input asp-for="Localizations[@i].Subtitle" class="form-control" placeholder="Subtitle" /></div>
                            <div class="col-md-4"><input asp-for="Localizations[@i].Description" class="form-control" placeholder="Description" /></div>
                        </div>
                    }
                </div>
            </div>

            <div class="admin-card p-4 mb-4">
                <div class="section-header mb-3">
                    <div>
                        <h2 class="section-title">Audio assets</h2>
                        <p class="section-subtitle">Thêm audio trực tiếp cho POI theo từng ngôn ngữ.</p>
                    </div>
                    <button type="button" class="btn btn-outline-primary btn-sm" data-add-row data-target="poi-audio-rows" data-prefix="AudioAssets">+ Add row</button>
                </div>
                <div id="poi-audio-rows" data-next-index="@Model.AudioAssets.Count">
                    @for (var i = 0; i < Model.AudioAssets.Count; i++)
                    {
                        <div class="row g-2 mb-3" data-repeat-row data-repeat-group="AudioAssets">
                            <div class="col-md-2"><select asp-for="AudioAssets[@i].LanguageCode" asp-items="Model.LanguageOptions" class="form-select"></select></div>
                            <div class="col-md-5"><input asp-for="AudioAssets[@i].AudioUrl" class="form-control" placeholder="Audio URL" /></div>
                            <div class="col-md-5"><input asp-for="AudioAssets[@i].Transcript" class="form-control" placeholder="Transcript" /></div>
                        </div>
                    }
                </div>
            </div>

            <div class="admin-card p-4">
                <div class="section-header mb-3">
                    <div>
                        <h2 class="section-title">Speech texts</h2>
                        <p class="section-subtitle">Nội dung speech theo từng ngôn ngữ.</p>
                    </div>
                    <button type="button" class="btn btn-outline-primary btn-sm" data-add-row data-target="poi-speech-rows" data-prefix="SpeechTexts">+ Add row</button>
                </div>
                <div id="poi-speech-rows" data-next-index="@Model.SpeechTexts.Count">
                    @for (var i = 0; i < Model.SpeechTexts.Count; i++)
                    {
                        <div class="row g-2 mb-3" data-repeat-row data-repeat-group="SpeechTexts" data-speech-text-row="true">
                            <div class="col-md-2"><select asp-for="SpeechTexts[@i].LanguageCode" asp-items="Model.LanguageOptions" class="form-select" data-speech-text-row-language="true"></select></div>
                            <div class="col-md-10"><textarea asp-for="SpeechTexts[@i].Text" rows="2" class="form-control" data-speech-text-row-text="true"></textarea></div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="preview-card sticky-top" style="top: 1rem;">
            <div class="preview-hero">
                <img data-live-preview="image" data-live-preview-source="ImageUrl" src="@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "https://placehold.co/800x600/png?text=POI+Preview" : Model.ImageUrl)" alt="POI preview" />
                <div class="preview-overlay"></div>
                <div class="preview-meta">
                    <div>
                        <div class="preview-title" data-live-preview="title" data-live-preview-source="Title">@(string.IsNullOrWhiteSpace(Model.Title) ? "POI Preview" : Model.Title)</div>
                        <div class="preview-subtitle" data-live-preview="subtitle" data-live-preview-source="Subtitle">@(string.IsNullOrWhiteSpace(Model.Subtitle) ? "Nhập thông tin để xem preview" : Model.Subtitle)</div>
                    </div>
                    <span class="soft-badge">Preview</span>
                </div>
            </div>
            <div class="preview-body">
                <div class="preview-stats">
                    <div class="preview-stat">
                        <div class="label">Category</div>
                        <div class="value" data-live-preview="category" data-live-preview-source="Category">@(string.IsNullOrWhiteSpace(Model.Category) ? "—" : Model.Category)</div>
                    </div>
                    <div class="preview-stat">
                        <div class="label">Language</div>
                        <div class="value" data-live-preview="language" data-live-preview-source="PrimaryLanguage">@(string.IsNullOrWhiteSpace(Model.PrimaryLanguage) ? "—" : Model.PrimaryLanguage)</div>
                    </div>
                    <div class="preview-stat">
                        <div class="label">Radius</div>
                        <div class="value" data-live-preview="radius" data-live-preview-source="GeofenceRadiusMeters" data-live-preview-format="meters">@($"{Model.GeofenceRadiusMeters:0} m")</div>
                    </div>
                </div>

                <div class="mini-map">
                    <div class="mini-map-pin"></div>
                </div>

                <ul class="preview-list">
                    <li><span>Location</span><strong data-live-preview="location" data-live-preview-source="Location">@(string.IsNullOrWhiteSpace(Model.Location) ? "—" : Model.Location)</strong></li>
                    <li><span>Lat / Lng</span><strong data-live-preview="latlng" data-live-preview-format="latlng">@($"{Model.Latitude:0.0000}, {Model.Longitude:0.0000}")</strong></li>
                    <li><span>Speech lang</span><strong data-live-preview="speech-lang" data-live-preview-source="SpeechTextLanguageCode">@(string.IsNullOrWhiteSpace(Model.SpeechTextLanguageCode) ? "—" : Model.SpeechTextLanguageCode)</strong></li>
                </ul>

                <div class="preview-speech-card mt-3">
                    <div class="label mb-1">Speech text</div>
                    <div class="preview-speech" data-live-preview="speech-text" data-live-preview-source="SpeechText">@(string.IsNullOrWhiteSpace(Model.SpeechText) ? "Nội dung speech sẽ hiển thị ở đây" : Model.SpeechText)</div>
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-primary w-100">Lưu POI</button>
                    <a asp-action="Index" class="btn btn-outline-light w-100">Hủy</a>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // After form submission, show a toast with the created link if available in response
        document.querySelector('form[data-live-preview-form]')?.addEventListener('submit', async (e) => {
            // Allow normal post; after server responds with redirect, browser will navigate.
            // For create, we show a quick client-side toast after the response if server returns JSON.
            // This is a progressive enhancement: serverside flow will still work.
            try {
                // attempt to submit via fetch to capture created ID
                e.preventDefault();
                const form = e.target;
                const action = form.getAttribute('action') || window.location.href;
                const formData = new FormData(form);
                const response = await fetch(action, { method: form.getAttribute('method') || 'POST', body: formData });
                if (response.ok) {
                    const text = await response.text();
                    // try to parse JSON with createdId
                    try {
                        const json = JSON.parse(text);
                        const id = json?.id ?? json?.Id;
                        if (id) {
                            const url = `${window.location.protocol}//${window.location.host}/poi/detail/${id}`;
                            showCopyableLink(url);
                            return;
                        }
                    } catch {
                        // not json - fallback: show generic message
                    }
                }
            } catch (err) {
                console.warn('Enhanced submit failed', err);
            }
            // fallback to normal submit
            e.target.submit();
        });

        function showCopyableLink(url) {
            const existing = document.getElementById('createdLinkToast');
            if (existing) existing.remove();
            const container = document.createElement('div');
            container.id = 'createdLinkToast';
            container.style.position = 'fixed';
            container.style.right = '1rem';
            container.style.bottom = '1rem';
            container.style.background = 'rgba(0,0,0,0.85)';
            container.style.color = 'white';
            container.style.padding = '1rem';
            container.style.borderRadius = '8px';
            container.style.boxShadow = '0 6px 18px rgba(0,0,0,0.32)';
            container.innerHTML = `<div style="font-weight:600;margin-bottom:.5rem">Link created</div><div style="word-break:break-all;margin-bottom:.5rem">${url}</div><div style="display:flex;gap:.5rem"><button id="copyLinkBtn" class="btn btn-sm btn-light">Copy</button><button id="closeLinkBtn" class="btn btn-sm btn-outline-light">Close</button></div>`;
            document.body.appendChild(container);
            document.getElementById('copyLinkBtn')?.addEventListener('click', () => {
                navigator.clipboard?.writeText(url);
                alert('Link copied to clipboard');
            });
            document.getElementById('closeLinkBtn')?.addEventListener('click', () => container.remove());
        }
    </script>
}
</div>
