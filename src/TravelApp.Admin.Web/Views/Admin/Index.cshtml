@model TravelApp.Admin.Web.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<!-- Toast thông báo đăng nhập -->
<div id="adminLoginToast" class="toast align-items-center text-white bg-primary border-0 position-fixed top-0 end-0 m-3" role="alert" aria-live="assertive" aria-atomic="true" style="z-index: 10000">
  <div class="d-flex">
    <div class="toast-body">
      <i class="bi bi-person-check-fill me-2"></i>
      Chào mừng Quản trị viên: <strong id="adminNameDisplay"></strong> đã quay lại!
    </div>
    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
  </div>
</div>

<div class="dashboard-grid">
    <section class="section-header">
        <div>
            <h1 class="section-title">Dashboard</h1>
            <p class="section-subtitle">Theo dõi nhanh dữ liệu tour, POI và hoạt động quản trị.</p>
        </div>
        <div class="section-actions">
            <span class="soft-badge">Live Connection: @Model.ApiBaseUrl</span>
        </div>
    </section>

    <section class="stats-row">
        <article class="stat-card">
            <div class="stat-icon stat-icon-orange">📍</div>
            <div>
                <div class="stat-value">@Model.PoiCount</div>
                <div class="stat-label">Tổng POI</div>
            </div>
        </article>

        <article class="stat-card">
            <div class="stat-icon stat-icon-green">👥</div>
            <div>
                <div class="stat-value">@Model.UserCount</div>
                <div class="stat-label">User</div>
            </div>
        </article>

        <article class="stat-card">
            <div class="stat-icon stat-icon-blue">🎧</div>
            <div>
                <div class="stat-value">@Model.PublishedTourCount</div>
                <div class="stat-label">Lượt nghe audio</div>
            </div>
        </article>

        <article class="stat-card">
            <div class="stat-icon stat-icon-purple">QR</div>
            <div>
                <div class="stat-value">@Model.QrCount</div>
                <div class="stat-label">Lượt quét QR</div>
            </div>
        </article>

        <article class="stat-card">
            <div class="stat-icon stat-icon-cyan" style="background: rgba(0, 255, 255, 0.1); color: #008b8b;">🌐</div>
            <div>
                <div class="stat-value">@Model.OnlineUserCount</div>
                <div class="stat-label">Trực tuyến</div>
            </div>
        </article>
    </section>

    <div class="row g-4 mt-1">
        <div class="col-lg-7">
            <section class="panel-card h-100">
                <div class="section-header mb-3">
                    <div>
                        <h2 class="section-title">📍 Xếp hạng địa điểm</h2>
                        <p class="section-subtitle">Dựa trên lượt quét QR và Audio.</p>
                    </div>
                </div>
                <div class="activity-list" id="ranking-list">
                    @{ int rank = 1; }
                    @foreach (var poi in Model.RecentPois)
                    {
                        var totalInteractions = poi.AudioPlays + poi.QrScans;
                        <div class="activity-item d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-3">
                                <div class="fw-bold text-secondary" style="width: 30px;">#@(rank++)</div>
                                <div>
                                    <strong class="d-block text-dark">@poi.Title - <span class="text-primary">@totalInteractions</span></strong>
                                    <small class="text-muted">@(poi.Category ?? "Địa điểm")</small>
                                </div>
                            </div>
                            <div class="text-muted small">
                                <i class="bi bi-headphones"></i> @poi.AudioPlays &nbsp; <i class="bi bi-qr-code"></i> @poi.QrScans
                            </div>
                        </div>
                    }
                </div>
            </section>
        </div>

        <div class="col-lg-5">
            <section class="panel-card h-100">
                <div class="section-header mb-3">
                    <div>
                        <h2 class="section-title">👥 Người dùng </h2>
                        <p class="section-subtitle">Truy cập gần đây (App/Web).</p>
                    </div>
                </div>
                <div class="activity-list" style="max-height: 400px; overflow-y: auto;">
                    @if (Model.OnlineUsers != null && Model.OnlineUsers.Any())
                    {
                        @foreach (var user in Model.OnlineUsers)
                        {
                            // Kiểm tra kỹ: Nếu tên bắt đầu bằng "Khách #" hoặc là "Anonymous" thì coi là khách
                            var name = user.Name?.Trim() ?? "";
                            bool isRegistered = !string.IsNullOrEmpty(name) && 
                                              !name.StartsWith("Khách #", StringComparison.OrdinalIgnoreCase) &&
                                              !name.Equals("Khách", StringComparison.OrdinalIgnoreCase) && 
                                              !name.Equals("Anonymous", StringComparison.OrdinalIgnoreCase);
                                              
                            <div class="activity-item py-2 border-bottom">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle @(user.ClientType == "Mobile" ? "bg-primary" : "bg-success")" 
                                             style="width: 10px; height: 10px; border-radius: 50%;" 
                                             title="@user.ClientType"></div>
                                        <span class="text-dark @(isRegistered ? "fw-bold" : "fw-medium")">
                                            @(isRegistered ? name : "Khách vãng lai")
                                        </span>
                                    </div>
                                    <span class="badge @(user.ClientType == "Mobile" ? "text-primary" : "text-success") bg-opacity-10" style="font-size: 0.65rem; border: 1px solid currentColor;">@user.Action.ToUpper()</span>
                                </div>
                                @if (isRegistered)
                                {
                                    <div class="ps-3 mt-1">
                                        <small class="text-muted" style="font-size: 0.75rem;">
                                            <i class="bi bi-lightning-charge-fill text-warning me-1"></i>
                                            @user.Action
                                        </small>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const adminName = localStorage.getItem('admin_login_success');
            if (adminName) {
                document.getElementById('adminNameDisplay').innerText = adminName;
                const toastEl = document.getElementById('adminLoginToast');
                const toast = new bootstrap.Toast(toastEl, { delay: 5000 });
                toast.show();
                localStorage.removeItem('admin_login_success');
            }
        });
    </script>
}
