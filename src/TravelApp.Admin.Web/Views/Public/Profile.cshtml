@using TravelApp.Admin.Web.Helpers
@{
    Layout = "_MobileLayout";
    var lang = Context.Request.Cookies["SelectedLanguage"] ?? "vi";
}
<style>
    body { background-color: #F6F7FB; }
    .profile-header { background-color: #E31667; padding: 48px 16px 16px 16px; color: white; }
    .back-circle { width: 40px; height: 40px; border-radius: 20px; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; }
    
    .profile-content { padding: 18px; display: flex; flex-direction: column; gap: 18px; }
    
    .info-card {
        background: white; border-radius: 16px; border: 1px solid #E6E6EA; padding: 14px;
        display: flex; align-items: center; gap: 12px;
    }
    .avatar-box {
        width: 66px; height: 66px; border-radius: 33px; background: #FAFAFB;
        border: 1px solid #ECECEF; display: flex; align-items: center; justify-content: center; font-size: 30px;
    }
    
    .section-label { font-size: 20px; font-weight: 700; color: #0D5B6C; margin-bottom: 10px; }
    
    .menu-group { background: white; border: 1px solid #ECECF1; border-radius: 14px; overflow: hidden; }
    .menu-row {
        display: flex; align-items: center; padding: 14px; gap: 12px;
        border-bottom: 1px solid #F0F0F3; cursor: pointer;
    }
    .menu-row:last-child { border-bottom: none; }
    .icon-wrap { width: 32px; height: 32px; border-radius: 16px; background: #FFF2F7; display: flex; align-items: center; justify-content: center; color: #D31963; }
    .menu-text { flex: 1; font-size: 18px; color: #1F1F24; }
    .menu-arrow { color: #9A9AA2; font-size: 22px; }

    .backup-card { background: white; border: 1px solid #ECECF1; border-radius: 14px; padding: 14px; }
    .btn-export { background: #E31667; color: white; border-radius: 16px; border: none; padding: 8px 16px; font-weight: bold; }
    .btn-import { background: #EEF2F8; color: #1B1C22; border-radius: 16px; border: none; padding: 8px 16px; font-weight: bold; }

    .btn-signout {
        background: #D61B63; color: white; border-radius: 28px; height: 54px;
        font-weight: 700; border: none; width: 100%; margin-top: 10px;
    }
</style>

<div class="profile-header d-flex align-items-center gap-3">
    <div class="back-circle" onclick="location.href='@Url.Action("Explore", "Public", new { area = "" })'"><i class="bi bi-chevron-left text-white"></i></div>
    <h1 class="m-0 fs-3 fw-bold">@WebLocalizationHelper.Get("Profile", lang)</h1>
</div>

<div class="profile-content">
    <div class="info-card shadow-sm">
        <div class="avatar-box">👤</div>
        <div>
            <div class="fw-bold fs-4">@WebLocalizationHelper.Get("Hi", lang)</div>
            <div class="text-secondary">@WebLocalizationHelper.Get("WelcomeBack", lang)</div>
        </div>
    </div>

    <div>
        <div class="section-label">@WebLocalizationHelper.Get("MyAccount", lang)</div>
        <div class="menu-group shadow-sm">
            <div class="menu-row">
                <div class="icon-wrap">👤</div>
                <div class="menu-text">@WebLocalizationHelper.Get("EditProfile", lang)</div>
                <div class="menu-arrow">›</div>
            </div>
            <div class="menu-row">
                <div class="icon-wrap">↓</div>
                <div class="menu-text">@WebLocalizationHelper.Get("Purchases", lang)</div>
                <div class="menu-arrow">›</div>
            </div>
        </div>
    </div>

    <div>
        <div class="section-label">@WebLocalizationHelper.Get("PreferencesLabel", lang)</div>
        <div class="menu-group shadow-sm">
            <div class="menu-row">
                <div class="icon-wrap" style="background: #EEF8FB; color: #0D5B6C;">⚙</div>
                <div class="menu-text">@WebLocalizationHelper.Get("UserPreferences", lang)</div>
                <div class="menu-arrow">›</div>
            </div>
            <div class="menu-row">
                <div class="icon-wrap">▮</div>
                <div class="menu-text">@WebLocalizationHelper.Get("Bookmarks", lang)</div>
                <div class="menu-arrow">›</div>
            </div>
        </div>
    </div>

    <button class="btn-signout shadow-sm" onclick="logout()">@WebLocalizationHelper.Get("Logout", lang)</button>
</div>