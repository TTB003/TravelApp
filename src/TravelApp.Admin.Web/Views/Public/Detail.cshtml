@model TravelApp.Application.Dtos.Pois.PoiMobileDto
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = Model.Title;
    var apiBaseUrl = ViewData["ApiBaseUrl"];
}

<div class="poi-hero-wrapper position-relative">
    <div class="poi-hero position-relative">
        <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://placehold.co/600x400/000/fff?text=POI" : Model.ImageUrl)" class="w-100" style="height: 400px; object-fit: cover;" />
        <div class="position-absolute top-0 start-0 w-100 p-3 d-flex justify-content-between">
            <a href="javascript:history.back()" class="btn btn-dark rounded-circle d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; background: rgba(0,0,0,0.5);"><i class="bi bi-chevron-left"></i></a>
            <button class="btn btn-dark rounded-circle d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; background: rgba(0,0,0,0.5);"><i class="bi bi-bookmark"></i></button>
        </div>
        <div class="position-absolute bottom-0 start-0 w-100 p-4" style="background: linear-gradient(transparent, #0F1115);">
            <span class="badge-category mb-2">@Model.Category</span>
            <h1 class="fw-bold mb-1">@Model.Title</h1>
            <div class="d-flex align-items-center text-white-50 small">
                <i class="bi bi-geo-alt-fill accent-color me-2"></i>
                <span>@Model.Location</span>
            </div>
        </div>
    </div>
</div>

<div class="container py-4 px-4">
    <div class="d-grid gap-3 mb-4">
        <button id="playBtn" class="btn btn-primary py-3 rounded-pill fw-bold shadow-lg" onclick="toggleAudio()">
            <i class="bi bi-play-circle-fill me-2 fs-5"></i> PHÁT HƯỚNG DẪN ÂM THANH
        </button>
        <audio id="mainAudio" src="@apiBaseUrl/api/pois/@Model.Id/audio"></audio>
    </div>

    <div class="mb-4">
        <h6 class="fw-bold text-uppercase text-secondary small mb-3">Giới thiệu</h6>
        <p class="text-light opacity-75" style="line-height: 1.8; white-space: pre-line; font-size: 1.05rem;">
            @Model.Description
        </p>
    </div>

    @if (!string.IsNullOrEmpty(Model.SpeechText))
    {
        <div class="bg-dark p-3 rounded-4 mb-4 border border-secondary border-opacity-25">
            <h6 class="fw-bold accent-color small mb-2"><i class="bi bi-chat-left-text-fill me-2"></i>Nội dung thuyết minh</h6>
            <p class="small text-secondary mb-0">@Model.SpeechText</p>
        </div>
    }

    <div class="bg-dark p-3 rounded-4 d-flex align-items-center justify-content-between">
        <div>
            <div class="small text-secondary">Tọa độ địa lý</div>
            <div class="fw-bold small">@Model.Latitude, @Model.Longitude</div>
        </div>
        <i class="bi bi-map-fill fs-4 accent-color"></i>
    </div>
</div>

@section Scripts {
    <script>
        const audio = document.getElementById('mainAudio');
        const miniPlayer = document.getElementById('miniPlayer');
        const miniPlayIcon = document.getElementById('miniPlayIcon');

        function toggleAudio() {
            if (audio.paused) {
                audio.play();
                miniPlayer.style.display = 'flex';
                document.getElementById('miniPlayerTitle').innerText = "@Model.Title";
                miniPlayIcon.className = "bi bi-pause-circle-fill fs-2";
            } else {
                audio.pause();
                miniPlayIcon.className = "bi bi-play-circle-fill fs-2";
            }
        }
    </script>
}