@model TravelApp.Application.Dtos.Pois.PoiMobileDto
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = Model.Title;
    var apiBaseUrl = (ViewData["ApiBaseUrl"]?.ToString() ?? "http://192.168.100.164:5293").TrimEnd('/');
    var heroImageUrl = string.IsNullOrEmpty(Model.ImageUrl) 
        ? "https://placehold.co/800x1000/161A21/8E94A4?text=POI" 
        : (Model.ImageUrl.StartsWith("http") ? Model.ImageUrl : $"{apiBaseUrl}/{Model.ImageUrl.TrimStart('/')}");
}

<div class="poi-hero-wrapper position-relative">
    <div class="poi-hero position-relative">
        <img src="@heroImageUrl" class="w-100" style="height: 600px; object-fit: cover;" />
        <div class="position-absolute top-0 start-0 w-100 p-4 d-flex justify-content-between" style="z-index: 10;">
            <a href="javascript:history.back()" class="btn btn-dark rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background: rgba(0,0,0,0.3); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.15);"><i class="bi bi-chevron-left fs-4"></i></a>
            <button class="btn btn-dark rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background: rgba(0,0,0,0.3); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.15);"><i class="bi bi-bookmark fs-4"></i></button>
        </div>
        <div class="position-absolute bottom-0 start-0 w-100 p-4 pb-5" style="background: linear-gradient(to top, #000000 20%, rgba(0,0,0,0.8) 50%, transparent 100%); padding-bottom: 110px !important;">
            <span class="badge-category mb-3" style="font-size: 11px; letter-spacing: 1px;">@Model.Category</span>
            <h1 class="fw-bold mb-2" style="font-size: 38px; letter-spacing: -1.5px; line-height: 1.1;">@Model.Title</h1>
            <div class="d-flex align-items-center" style="color: rgba(255,255,255,0.9);">
                <i class="bi bi-geo-alt-fill me-2" style="color: #E31667;"></i>
                <span class="fw-semibold">@Model.Location</span>
            </div>
        </div>
    </div>
</div>

<div class="container py-4 px-4">
    <div class="mb-5 text-center position-relative" style="z-index: 20; margin-top: -95px;">
        <button id="playBtn" class="btn py-3 rounded-pill fw-bold w-100 d-flex align-items-center justify-content-center" style="background-color: #E31667; color: white; height: 76px; font-size: 18px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; box-shadow: 0 20px 40px rgba(227, 22, 103, 0.45); border: none;" onclick="toggleAudio()">
            <i class="bi bi-play-circle-fill me-3 fs-3"></i> NGHE THUYẾT MINH AUDIO
        </button>
        <audio id="mainAudio" src="@apiBaseUrl/api/pois/@Model.Id/audio"></audio>
    </div>

    <div class="mb-4">
        <h6 class="fw-bold text-uppercase text-secondary small mb-3">Giới thiệu</h6>
        <p class="text-light opacity-75" style="line-height: 1.8; white-space: pre-line; font-size: 1.05rem;">
            @Model.Description
        </p>
    </div>

    @if (!string.IsNullOrEmpty(Model.SpeechText))
    {
        <div class="bg-dark p-3 rounded-4 mb-4 border border-secondary border-opacity-25">
            <h6 class="fw-bold accent-color small mb-2"><i class="bi bi-chat-left-text-fill me-2"></i>Nội dung thuyết minh</h6>
            <p class="small text-secondary mb-0">@Model.SpeechText</p>
        </div>
    }

    <div class="bg-dark p-3 rounded-4 d-flex align-items-center justify-content-between">
        <div>
            <div class="small text-secondary">Tọa độ địa lý</div>
            <div class="fw-bold small">@Model.Latitude, @Model.Longitude</div>
        </div>
        <i class="bi bi-map-fill fs-4 accent-color"></i>
    </div>
</div>

@section Scripts {
    <script>
        const audio = document.getElementById('mainAudio');
        const miniPlayer = document.getElementById('miniPlayer');
        const miniPlayIcon = document.getElementById('miniPlayIcon');

        function toggleAudio() {
            if (audio.paused) {
                audio.play();
                miniPlayer.style.display = 'flex';
                document.getElementById('miniPlayerTitle').innerText = "@Model.Title";
                miniPlayIcon.className = "bi bi-pause-circle-fill fs-2";
            } else {
                audio.pause();
                miniPlayIcon.className = "bi bi-play-circle-fill fs-2";
            }
        }
    </script>
}