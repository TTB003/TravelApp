@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Quét mã QR";
}

<div class="container py-4 text-center">
    <div class="d-flex justify-content-between align-items-center mb-4 px-2">
        <a href="javascript:history.back()" class="btn btn-link p-0 text-white"><i class="bi bi-arrow-left fs-3"></i></a>
        <div class="text-center">
            <h4 class="fw-bold mb-0">Quét mã QR</h4>
            <p class="text-secondary small mb-0">Mở nhanh thông tin địa điểm</p>
        </div>
        <div class="bg-secondary bg-opacity-25 rounded-circle p-2" style="width: 44px; height: 44px;">
            <span class="small fw-bold">QR</span>
        </div>
    </div>

    <div id="reader-container" class="position-relative overflow-hidden rounded-5 mb-4" style="background: #000; height: 400px;">
        <div id="reader"></div>
        <div class="qr-overlay"></div>
    </div>

    <div class="info-card-mobile text-start p-4">
        <h6 class="fw-bold text-dark mb-2">Lưu ý</h6>
        <p class="text-muted small mb-3">
            Mã QR hợp lệ có thể là số POI trực tiếp hoặc URL chứa mã địa điểm. 
            Hệ thống sẽ tự động mở trang chi tiết ngay khi nhận diện thành công.
        </p>
        <div id="scan-status" class="accent-color fw-bold small">
            <i class="bi bi-camera-fill me-2"></i> Đang chờ quét mã...
        </div>
        
        <div class="mt-3 pt-3 border-top">
            <button class="btn btn-light w-100 rounded-4 py-2 small fw-bold" onclick="pasteQrContent()">
                <i class="bi bi-clipboard-check me-2"></i> Paste QR content
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const html5QrCode = new Html5Qrcode("reader");
        const qrCodeSuccessCallback = (decodedText, decodedResult) => {
            document.getElementById('scan-status').innerHTML = "Đã tìm thấy mã! Đang chuyển hướng...";
            html5QrCode.stop().then(() => {
                // Giải mã URL và trích xuất ID (logic tương tự QrCodeParserService)
                window.location.href = decodedText;
            });
        };

        const config = { fps: 15, qrbox: { width: 260, height: 260 } };

        html5QrCode.start({ facingMode: "environment" }, config, qrCodeSuccessCallback)
            .then(() => { document.getElementById('scan-status').innerHTML = "Hãy đưa mã QR vào khung"; })
            .catch(err => {
                document.getElementById('scan-status').innerHTML = "Cần quyền camera để quét";
            });

        async function pasteQrContent() {
            const text = await navigator.clipboard.readText();
            if (text) window.location.href = text;
        }
    </script>
    <style>
        #reader { width: 100% !important; border: none !important; height: 100%; }
        #reader video { object-fit: cover; height: 100%; }
        .qr-overlay {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            width: 260px; height: 260px;
            border: 3px solid #E31667; border-radius: 24px;
            box-shadow: 0 0 0 1000px rgba(0,0,0,0.5);
            pointer-events: none; z-index: 10;
        }
        .info-card-mobile { background: #FFFFFF; border-radius: 24px; margin-top: -20px; position: relative; z-index: 20; }
    </style>
}