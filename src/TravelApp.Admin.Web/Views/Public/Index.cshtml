@model IReadOnlyList<TravelApp.Application.Dtos.Pois.PoiMobileDto>
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Khám phá";
    var apiBaseUrl = (ViewData["ApiBaseUrl"]?.ToString() ?? "http://192.168.100.164:5293").TrimEnd('/');
}

<div class="container py-4 px-3">
    <div class="d-flex justify-content-between align-items-center mb-4 px-1">
        <h1 class="section-title mb-0" style="font-size: 34px; font-weight: 800; letter-spacing: -1px;">Khám phá</h1>
        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background: #1C2129; border: 1px solid rgba(255,255,255,0.1);">
            <i class="bi bi-person-fill fs-4 text-white-50"></i>
        </div>
    </div>

    <div class="d-flex gap-2 overflow-auto pb-4 no-scrollbar" style="margin: 0 -1rem; padding: 0 1rem;">
        <a href="#" class="category-chip active">Tất cả</a>
        <a href="#" class="category-chip">Lịch sử</a>
        <a href="#" class="category-chip">Ẩm thực</a>
        <a href="#" class="category-chip">Kiến trúc</a>
        <a href="#" class="category-chip">Bảo tàng</a>
    </div>

    <h5 class="fw-bold mb-3 px-1 mt-2" style="font-size: 22px; letter-spacing: -0.5px;">Dành cho bạn</h5>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 mt-4" style="background: #161A21; border-radius: 28px; border: 1px dashed rgba(255,255,255,0.1);">
            <i class="bi bi-cloud-slash fs-1 d-block mb-3 text-secondary opacity-50"></i>
            <p class="text-secondary mb-1">Không tìm thấy dữ liệu địa điểm</p>
            <small class="text-muted">Đang kết nối tới: @apiBaseUrl</small>
        </div>
    }

    <div class="row">
        @foreach (var poi in Model ?? Enumerable.Empty<TravelApp.Application.Dtos.Pois.PoiMobileDto>())
        {
            <div class="col-12">
                <a href="/Public/Poi/@poi.Id" class="text-decoration-none">
                    <div class="card poi-card position-relative">
                        @{
                            var imageUrl = string.IsNullOrEmpty(poi.ImageUrl) 
                                ? "https://placehold.co/800x600/161A21/8E94A4?text=Chưa+có+hình+ảnh" 
                                : (poi.ImageUrl.StartsWith("http") ? poi.ImageUrl : $"{apiBaseUrl}/{poi.ImageUrl.TrimStart('/')}");
                        }
                        <img src="@imageUrl" alt="@poi.Title" style="height: 280px;">
                        <div class="card-body p-4" style="background: linear-gradient(to bottom, #1B1F28, #161A21);">
                            <span class="badge-category mb-3 d-inline-block" style="font-size: 11px; padding: 5px 12px;">@poi.Category</span>
                            <h5 class="card-title text-white fw-bold mb-2" style="font-size: 22px; letter-spacing: -0.5px;">@poi.Title</h5>
                            <p class="card-text text-white-50 small mb-0"><i class="bi bi-geo-alt-fill me-2 accent-color"></i>@poi.Location</p>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>

<style>
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>