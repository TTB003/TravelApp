<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelApp.NowPlayingPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F6F7FB, Dark=#111318}">

    <Grid RowDefinitions="Auto,*" Padding="20,52,20,20">
        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
            <Button Text="←"
                    Command="{Binding BackCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#1B1F28, Dark=#F3F5FA}"
                    FontSize="24"
                    Padding="0" />

            <Label Grid.Column="1"
                   Text="Now Playing"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#1B1F28, Dark=#F3F5FA}"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center" />
        </Grid>

        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#181C24}"
                Stroke="{AppThemeBinding Light=#E8EBF2, Dark=#2A2F3A}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 28"
                Padding="20">
            <VerticalStackLayout Spacing="18" VerticalOptions="Center">
                <Border WidthRequest="110"
                        HeightRequest="110"
                        StrokeThickness="0"
                        BackgroundColor="#E31667"
                        StrokeShape="RoundRectangle 55"
                        HorizontalOptions="Center">
                    <Label Text="▶"
                           FontSize="52"
                           TextColor="White"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </Border>

                <Label Text="{Binding StatusText}"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="#D11A5B"
                       HorizontalTextAlignment="Center" />

                <Label Text="{Binding PoiTitle}"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#1B1F28, Dark=#F3F5FA}"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap"
                       MaxLines="3" />

                <Label Text="{Binding LanguageText}"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#6E7380, Dark=#B4BDCF}"
                       HorizontalTextAlignment="Center" />

                <Button Text="{Binding ActionButtonText}"
                        Command="{Binding ActionCommand}"
                        BackgroundColor="#E31667"
                        TextColor="White"
                        HeightRequest="58"
                        CornerRadius="29"
                        FontAttributes="Bold"
                        FontSize="18"
                        Margin="0,6,0,0" />
            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
