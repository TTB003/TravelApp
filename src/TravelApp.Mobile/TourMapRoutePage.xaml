<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:TravelApp.Mobile.Services"
             x:Class="TravelApp.TourMapRoutePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F6F7FB, Dark=#111318}">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="16,48,16,12">
        <Grid ColumnDefinitions="40,*" ColumnSpacing="10">
            <Border WidthRequest="40"
                    HeightRequest="40"
                    Stroke="{AppThemeBinding Light=#D6DCE8, Dark=#343B4A}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 20"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#181C24}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding BackCommand}" />
                </Border.GestureRecognizers>
                <Path Data="M15.4,4.6L14,3.2L5.2,12L14,20.8L15.4,19.4L8,12L15.4,4.6Z"
                      Fill="{AppThemeBinding Light=#333A4A, Dark=#F3F5FA}"
                      WidthRequest="16"
                      HeightRequest="16"
                      HorizontalOptions="Center"
                      VerticalOptions="Center" />
            </Border>

            <Label Grid.Column="1"
                   Text="{Binding LiveRouteText, Source={x:Static services:LocalizationManager.Instance}}"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#1B1F28, Dark=#F3F5FA}"
                   VerticalTextAlignment="Center" />
        </Grid>

        <Label Grid.Row="1"
               Margin="0,8,0,10"
               Text="{Binding StatusText}"
               FontSize="13"
               TextColor="{AppThemeBinding Light=#6E7380, Dark=#B4BDCF}" />

        <Grid Grid.Row="2">
            <Border Stroke="{AppThemeBinding Light=#E8EBF2, Dark=#2A2F3A}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#181C24}">
                <Grid x:Name="TourMapContainer" />
            </Border>

            <Border HorizontalOptions="Start"
                    VerticalOptions="End"
                    Margin="12,12,12,16"
                    Padding="14"
                    StrokeThickness="1"
                    Stroke="#E31667"
                    StrokeShape="RoundRectangle 18"
                    BackgroundColor="{AppThemeBinding Light=#FFF8FB, Dark=#23141C}">
                <Grid ColumnDefinitions="6,*,Auto" ColumnSpacing="10">
                    <BoxView WidthRequest="6"
                             Color="#E31667" />

                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                        <Label Text="{Binding NowPlayingText, Source={x:Static services:LocalizationManager.Instance}}" FontSize="11" TextColor="#E31667" FontAttributes="Bold" />
                        <Label Text="{Binding CurrentWaypointTitle}"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#1B1F28, Dark=#F3F5FA}"
                               LineBreakMode="TailTruncation" />
                        <Label Text="{Binding CurrentWaypointSubtitle}"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#6E7380, Dark=#B4BDCF}"
                               LineBreakMode="TailTruncation" />
                        <ProgressBar Progress="{Binding CurrentWaypointProgressValue}"
                                     HeightRequest="4"
                                     HorizontalOptions="Fill"
                                     Margin="0,4,0,0" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="2" Spacing="2" HorizontalOptions="End" VerticalOptions="Center">
                        <Label Text="{Binding CurrentWaypointProgressText}"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#E31667"
                               HorizontalTextAlignment="End" />
                        <Label Text="{Binding StopsText, Source={x:Static services:LocalizationManager.Instance}}"
                               FontSize="10"
                               TextColor="{AppThemeBinding Light=#8A93A6, Dark=#9EA8BC}"
                               HorizontalTextAlignment="End" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Border HorizontalOptions="End"
                    VerticalOptions="Start"
                    Margin="0,12,12,0"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#181C24}"
                    StrokeShape="RoundRectangle 20">
                <Button Text="◎"
                        Command="{Binding RecenterCommand}"
                        WidthRequest="48"
                        HeightRequest="48"
                        CornerRadius="24"
                        FontSize="20"
                        BackgroundColor="#E31667"
                        TextColor="White" />
            </Border>

            <Border HorizontalOptions="Start"
                    VerticalOptions="Start"
                    Margin="12"
                    Padding="12,8"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 14"
                    BackgroundColor="#AA111318">
                <Label Text="{Binding Tour.Name}"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="White" />
            </Border>
        </Grid>

        <CollectionView Grid.Row="3" ItemsSource="{Binding Waypoints}" SelectionMode="None" Margin="0,10,0,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="{AppThemeBinding Light=#E8EBF2, Dark=#2A2F3A}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#181C24}"
                            Padding="12"
                            Margin="0,0,0,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectWaypointCommand}"
                                                  CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="True">
                                <Setter Property="Stroke" Value="#E31667" />
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#FFF2F7, Dark=#2A1A24}" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Border WidthRequest="30"
                                    HeightRequest="30"
                                    Stroke="#3F7DFF"
                                    StrokeThickness="1.5"
                                    StrokeShape="RoundRectangle 15"
                                    BackgroundColor="Transparent"
                                    VerticalOptions="Center">
                                <Label Text="{Binding SortOrder}"
                                       TextColor="#3F7DFF"
                                       FontAttributes="Bold"
                                       FontSize="13"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Stroke" Value="#E31667" />
                                        <Setter Property="BackgroundColor" Value="#22E31667" />
                                    </DataTrigger>
                                </Border.Triggers>
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <HorizontalStackLayout Spacing="6">
                                    <HorizontalStackLayout Spacing="3">
                                        <Label Text="{Binding StopText, Source={x:Static services:LocalizationManager.Instance}}" FontSize="11" TextColor="#E31667" />
                                        <Label Text="{Binding SortOrder}" FontSize="11" TextColor="#E31667" />
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding NowPlayingText, Source={x:Static services:LocalizationManager.Instance}, Converter={StaticResource UpperCaseConverter}}" FontSize="10" TextColor="White" BackgroundColor="#E31667" Padding="8,2" HorizontalOptions="Start">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsActive}" Value="False">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </HorizontalStackLayout>
                                <Label Text="{Binding Title}" FontSize="15" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                                <Label Text="{Binding Location}" FontSize="12" TextColor="{AppThemeBinding Light=#6E7380, Dark=#B4BDCF}" LineBreakMode="TailTruncation" />
                                <Label Text="{Binding DistanceMeters, StringFormat='{0:F0} m'}"
                                       FontSize="11"
                                       TextColor="{AppThemeBinding Light=#8A93A6, Dark=#9EA8BC}" />
                            </VerticalStackLayout>

                            <Button Grid.Column="2"
                                    Text="{Binding OpenText, Source={x:Static services:LocalizationManager.Instance}}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenPoiCommand}"
                                    CommandParameter="{Binding .}"
                                    FontSize="12"
                                    HeightRequest="32"
                                    WidthRequest="72"
                                    CornerRadius="16"
                                    BackgroundColor="#E31667"
                                    TextColor="White"
                                    VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
