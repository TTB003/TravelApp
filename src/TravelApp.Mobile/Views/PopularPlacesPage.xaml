<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:TravelApp.Mobile.Services"
             x:Class="TravelApp.Mobile.Views.PopularPlacesPage"
             Title="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=HeatmapText}">
    
    <Grid>
        <!-- URL này trỏ về địa chỉ trang web Admin của bạn -->
        <WebView x:Name="HeatmapWebView" 
                 Source="http://192.168.100.164:7020/Tours/Heatmap"
                 VerticalOptions="FillAndExpand" 
                 HorizontalOptions="FillAndExpand" />
    </Grid>
</ContentPage>