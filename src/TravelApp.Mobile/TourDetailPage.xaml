<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelApp.TourDetailPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource TravelPageLight}, Dark={StaticResource TravelPageDark}}">

    <Grid RowDefinitions="300,*">
        <Grid Grid.Row="0">
            <Image Source="{Binding Tour.ImageUrl}" Aspect="AspectFill" />

            <Grid Padding="18,52,18,0" ColumnDefinitions="56,*,56" VerticalOptions="Start">
                <Border BackgroundColor="#E31667" StrokeThickness="0" WidthRequest="56" HeightRequest="56" StrokeShape="RoundRectangle 28">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding BackCommand}" />
                    </Border.GestureRecognizers>
                    <Path Data="M15.4,4.6L14,3.2L5.2,12L14,20.8L15.4,19.4L8,12L15.4,4.6Z"
                          Fill="White"
                          WidthRequest="18"
                          HeightRequest="18"
                          HorizontalOptions="Center"
                          VerticalOptions="Center" />
                </Border>
                <Border x:Name="BookmarkButton"
                        Grid.Column="2"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1B1E25}"
                        Stroke="#E7D3DF"
                        StrokeThickness="1.2"
                        WidthRequest="56"
                        HeightRequest="56"
                        StrokeShape="RoundRectangle 28">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBookmarkTapped" />
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,*" Padding="0,5,0,3">
                        <Border Grid.Row="0"
                                HorizontalOptions="Center"
                                VerticalOptions="Start"
                                BackgroundColor="#E31667"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 10"
                                Padding="6,1"
                                IsVisible="{Binding IsBookmarked}">
                            <Label Text="Saved"
                                   FontSize="9"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalTextAlignment="Center" />
                        </Border>

                        <Grid Grid.Row="1" WidthRequest="24" HeightRequest="24" HorizontalOptions="Center" VerticalOptions="Center">
                            <Path Data="M6,5H18C18.55,5 19,5.45 19,6V18C19,18.55 18.55,19 18,19H6C5.45,19 5,18.55 5,18V6C5,5.45 5.45,5 6,5M7,7V17H17V7H7Z"
                                  Fill="Transparent"
                                  Stroke="#C2185B"
                                  StrokeThickness="1.9"
                                  WidthRequest="20"
                                  HeightRequest="20"
                                  HorizontalOptions="Center"
                                  VerticalOptions="Center" />
                            <Path Data="M6,5H18C18.55,5 19,5.45 19,6V18C19,18.55 18.55,19 18,19H6C5.45,19 5,18.55 5,18V6C5,5.45 5.45,5 6,5M7,7V17H17V7H7Z"
                                  Fill="#E31667"
                                  WidthRequest="20"
                                  HeightRequest="20"
                                  HorizontalOptions="Center"
                                  VerticalOptions="Center">
                                <Path.Triggers>
                                    <DataTrigger TargetType="Path" Binding="{Binding IsBookmarked}" Value="False">
                                        <Setter Property="Opacity" Value="0" />
                                    </DataTrigger>
                                </Path.Triggers>
                            </Path>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="1" BackgroundColor="{AppThemeBinding Light=#F6F6F8, Dark=#111318}" StrokeThickness="0" StrokeShape="RoundRectangle 0" Padding="18,18,18,12">
            <ScrollView>
                <VerticalStackLayout Spacing="12">
                    <!-- Language chips -->
                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Fill" VerticalOptions="Center">
                        <Border Padding="6,4" StrokeShape="RoundRectangle 20" BackgroundColor="{Binding SelectedSpeechLanguageCode, Converter={StaticResource LangToBackgroundConverter}, ConverterParameter='vi'}">
                            <Label Text="VN" TextColor="White" FontAttributes="Bold">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectLanguageSimpleCommand}" CommandParameter="vi" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Border>
                        <Border Padding="6,4" StrokeShape="RoundRectangle 20" BackgroundColor="{Binding SelectedSpeechLanguageCode, Converter={StaticResource LangToBackgroundConverter}, ConverterParameter='en'}">
                            <Label Text="EN" TextColor="White" FontAttributes="Bold">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectLanguageSimpleCommand}" CommandParameter="en" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Border>
                    </HorizontalStackLayout>

                    <Label Text="{Binding Tour.Title}" FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#2C2D33, Dark=#EEF1F8}" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="{Binding Tour.Location}" FontSize="16" TextColor="{AppThemeBinding Light=#8A8B92, Dark=#B4BDCF}" />
                        <Label Grid.Column="1" Text="{Binding Tour.Price}" FontSize="22" TextColor="#D31963" FontAttributes="Bold" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Border Stroke="{AppThemeBinding Light=#CFD4D9, Dark=#2A2F3A}" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="10,8">
                            <Label Text="{Binding Tour.Subtitle, StringFormat='🕴  {0}'}" FontSize="14" TextColor="#1C6272" />
                        </Border>

                    <!-- Audio Player Card -->
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#8A2BE2" Offset="0" />
                                <GradientStop Color="#00CED1" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border StrokeShape="RoundRectangle 12" Padding="12" Margin="0,8">
                            <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                                <Button Text="▶" WidthRequest="52" HeightRequest="52" CornerRadius="26" BackgroundColor="#FFFFFF33" Command="{Binding PlayAudioCommand}" />
                                <StackLayout Grid.Column="1" VerticalOptions="Center" Padding="10,0">
                                    <Label Text="Thuyết minh" TextColor="White" FontAttributes="Bold" />
                                    <Label Text="Bấm Play để nghe hướng dẫn" TextColor="#EDEDF5" FontSize="12" />
                                    <Slider Minimum="0" Maximum="100" Value="{Binding PlayerProgress}" BackgroundColor="#FFFFFF33" />
                                </StackLayout>
                                <Button Grid.Column="2" Text="⏹" WidthRequest="44" HeightRequest="44" CornerRadius="22" BackgroundColor="#FFFFFF22" Command="{Binding StopAudioCommand}" />
                            </Grid>
                        </Border>
                    </Border>

                    <!-- QR Block: display at end so users can share or scan -->
                    <StackLayout HorizontalOptions="Center" VerticalOptions="End" Margin="0,12">
                        <Label Text="QUÉT ĐỂ XEM CHI TIẾT &amp; CHIA SẺ" FontAttributes="Bold" HorizontalOptions="Center" TextTransform="Uppercase" />
                        <Border StrokeThickness="1" Stroke="White" BackgroundColor="#111111" Padding="8" StrokeShape="RoundRectangle 8" Margin="0,8">
                            <Image Source="{Binding Tour.QrImageUrl}" WidthRequest="160" HeightRequest="160" Aspect="AspectFit" />
                        </Border>
                        <Label Text="Chia sẻ trang POI với bạn bè bằng mã QR" FontSize="12" TextColor="#FFFFFF" HorizontalOptions="Center" />
                    </StackLayout>
                        <Border Grid.Column="1" Stroke="{AppThemeBinding Light=#CFD4D9, Dark=#2A2F3A}" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="10,8">
                            <Label Text="{Binding Tour.Distance, StringFormat='⇄  {0}'}" FontSize="14" TextColor="#1C6272" />
                        </Border>
                        <Border Grid.Column="2" Stroke="{AppThemeBinding Light=#CFD4D9, Dark=#2A2F3A}" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="10,8">
                            <Label Text="{Binding Tour.Duration, StringFormat='◷  {0}'}" FontSize="14" TextColor="#1C6272" />
                        </Border>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E7E8EC, Dark=#2A2F3A}" Margin="0,2" />

                    <Grid ColumnDefinitions="Auto" ColumnSpacing="8">
                        <Border Stroke="#D31963"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 27"
                                BackgroundColor="#FFF4F8"
                                Padding="16,0"
                                HeightRequest="54">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding DownloadTourCommand}" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                                <Path Data="M12,4V14M12,14L8,10M12,14L16,10M6,18H18"
                                      Stroke="#D31963"
                                      StrokeThickness="2"
                                      WidthRequest="18"
                                      HeightRequest="18"
                                      HorizontalOptions="Center"
                                      VerticalOptions="Center" />
                                <Label Text="Download tour"
                                       TextColor="#D31963"
                                       FontSize="16"
                                       VerticalTextAlignment="Center" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="*" Margin="0,4,0,0">
                        <Label Text="Description" TextColor="#D31963" FontSize="16" HorizontalTextAlignment="Center" FontAttributes="Bold" />
                    </Grid>
                    <BoxView HeightRequest="2" Color="#D31963" HorizontalOptions="Fill" />
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E7E8EC, Dark=#2A2F3A}" Margin="0,-10,0,0" />

                    <Label FontSize="16">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Provided by " TextColor="{AppThemeBinding Light=#2B2D33, Dark=#EEF1F8}" />
                                <Span Text="{Binding ProviderName}" TextColor="#1C6272" TextDecorations="Underline" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                    <Label Text="{Binding Description}" FontSize="16" TextColor="{AppThemeBinding Light=#2B2D33, Dark=#D7DEEC}" LineBreakMode="WordWrap" />

                    <Label Text="{Binding Credit}" FontSize="14" TextColor="#2D89C8" TextDecorations="Underline" LineBreakMode="WordWrap" />

                    <Border Stroke="{AppThemeBinding Light=#E3E7EE, Dark=#2A2F3A}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#181C24}"
                            Padding="14">
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Text to Speech" FontSize="16" FontAttributes="Bold" TextColor="#D31963" />
                                <Border Grid.Column="1"
                                        Stroke="#D31963"
                                        StrokeThickness="1.4"
                                        StrokeShape="RoundRectangle 18"
                                        BackgroundColor="#FFF4F8"
                                        Padding="12,6">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleSpeechLanguageMenuCommand}" />
                                    </Border.GestureRecognizers>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding CanEditSpeechText}" Value="False">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label Text="{Binding SelectedSpeechLanguageDisplayText}"
                                           FontSize="14"
                                           TextColor="#D31963"
                                           VerticalTextAlignment="Center" />
                                </Border>
                            </Grid>

                            <VerticalStackLayout Spacing="8">
                                <VerticalStackLayout.Triggers>
                                    <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding CanEditSpeechText}" Value="False">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                </VerticalStackLayout.Triggers>

                                <Editor Text="{Binding SpeechTextInput}"
                                        Unfocused="OnSpeechTextEditorUnfocused"
                                        AutoSize="TextChanges"
                                        Placeholder="Nhập nội dung sẽ được đọc khi phát audio..."
                                        BackgroundColor="Transparent"
                                        TextColor="{AppThemeBinding Light=#2B2D33, Dark=#EEF1F8}"
                                        HeightRequest="140" />
                                <Button Text="Lưu text TTS"
                                        Command="{Binding SaveSpeechTextCommand}"
                                        Style="{StaticResource PrimaryPillButtonStyle}"
                                        HeightRequest="52"
                                        CornerRadius="26"
                                        FontSize="18" />
                            </VerticalStackLayout>

                            <Border Stroke="#D31963"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="#FFF4F8"
                                    Padding="12,10">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding CanEditSpeechText}" Value="True">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label Text="Chỉ tài khoản có role Owner hoặc Admin mới được sửa text to speech trực tiếp trên app."
                                       FontSize="13"
                                       TextColor="#B51A50"
                                       LineBreakMode="WordWrap" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <Grid ColumnDefinitions="*" Margin="0,10,0,10">
                        <Button Text="View Tour"
                                Command="{Binding ViewTourCommand}"
                                Style="{StaticResource PrimaryPillButtonStyle}"
                                HeightRequest="58"
                                CornerRadius="28"
                                FontSize="20" />
                    </Grid>
                </VerticalStackLayout>
            </ScrollView>
        </Border>

        <Grid Grid.RowSpan="2" IsVisible="{Binding IsSpeechLanguageMenuOpen}" InputTransparent="False">
            <BoxView Color="#77000000" />
            <Border VerticalOptions="Start"
                    Margin="0,120,0,0"
                    BackgroundColor="#212121"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24,24,0,0"
                    Padding="0,14,0,20">
                <ScrollView>
                    <VerticalStackLayout Padding="16,0" Spacing="12">
                        <Grid ColumnDefinitions="*,Auto" Padding="8,0,8,0">
                            <Label Text="Chọn ngôn ngữ TTS" FontSize="22" FontAttributes="Bold" TextColor="White" />
                            <Button Grid.Column="1"
                                    Text="✕"
                                    Command="{Binding CloseSpeechLanguageMenuCommand}"
                                    FontSize="22"
                                    TextColor="White"
                                    BackgroundColor="Transparent"
                                    Padding="0" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="#2A2F3A" />

                        <CollectionView ItemsSource="{Binding SpeechLanguages}" SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Stroke="#303746"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 16"
                                            BackgroundColor="#2A2F3A"
                                            Padding="14,12">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectSpeechLanguageCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BackgroundColor" Value="#374151" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Text="{Binding DisplayName}" FontSize="16" TextColor="White" />
                                            <Label Grid.Column="1" Text="✓" TextColor="#00CED1" FontSize="18">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="False">
                                                        <Setter Property="Text" Value="" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
