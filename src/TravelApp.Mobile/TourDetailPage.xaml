<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelApp.TourDetailPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource TravelPageLight}, Dark={StaticResource TravelPageDark}}">

    <Grid RowDefinitions="300,*">
        <Grid Grid.Row="0">
            <Image Source="{Binding Tour.ImageUrl}" Aspect="AspectFill" />

            <Grid Padding="18,52,18,0" ColumnDefinitions="56,*,56" VerticalOptions="Start">
                <Border BackgroundColor="#E31667" StrokeThickness="0" WidthRequest="56" HeightRequest="56" StrokeShape="RoundRectangle 28">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding BackCommand}" />
                    </Border.GestureRecognizers>
                    <Path Data="M15.4,4.6L14,3.2L5.2,12L14,20.8L15.4,19.4L8,12L15.4,4.6Z"
                          Fill="White"
                          WidthRequest="18"
                          HeightRequest="18"
                          HorizontalOptions="Center"
                          VerticalOptions="Center" />
                </Border>

                <Border Grid.Column="2" BackgroundColor="White" StrokeThickness="0" WidthRequest="56" HeightRequest="56" StrokeShape="RoundRectangle 28">
                    <Path Data="M6,5H18C18.55,5 19,5.45 19,6V18C19,18.55 18.55,19 18,19H6C5.45,19 5,18.55 5,18V6C5,5.45 5.45,5 6,5M7,7V17H17V7H7Z"
                          Fill="#C2185B"
                          WidthRequest="18"
                          HeightRequest="18"
                          HorizontalOptions="Center"
                          VerticalOptions="Center" />
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="1" BackgroundColor="{AppThemeBinding Light=#F6F6F8, Dark=#111318}" StrokeThickness="0" StrokeShape="RoundRectangle 0" Padding="18,18,18,12">
            <ScrollView>
                <VerticalStackLayout Spacing="12">
                    <Label Text="{Binding Tour.Title}" FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#2C2D33, Dark=#EEF1F8}" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="{Binding Tour.Location}" FontSize="16" TextColor="{AppThemeBinding Light=#8A8B92, Dark=#B4BDCF}" />
                        <Label Grid.Column="1" Text="{Binding Tour.Price}" FontSize="22" TextColor="#D31963" FontAttributes="Bold" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Border Stroke="{AppThemeBinding Light=#CFD4D9, Dark=#2A2F3A}" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="10,8">
                            <Label Text="{Binding Tour.Subtitle, StringFormat='🕴  {0}'}" FontSize="14" TextColor="#1C6272" />
                        </Border>
                        <Border Grid.Column="1" Stroke="{AppThemeBinding Light=#CFD4D9, Dark=#2A2F3A}" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="10,8">
                            <Label Text="{Binding Tour.Distance, StringFormat='⇄  {0}'}" FontSize="14" TextColor="#1C6272" />
                        </Border>
                        <Border Grid.Column="2" Stroke="{AppThemeBinding Light=#CFD4D9, Dark=#2A2F3A}" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="10,8">
                            <Label Text="{Binding Tour.Duration, StringFormat='◷  {0}'}" FontSize="14" TextColor="#1C6272" />
                        </Border>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E7E8EC, Dark=#2A2F3A}" Margin="0,2" />

                    <Grid ColumnDefinitions="54,54,*,98" ColumnSpacing="8">
                        <Border Stroke="{AppThemeBinding Light=#E3E4E8, Dark=#2A2F3A}" StrokeThickness="1" StrokeShape="RoundRectangle 27" BackgroundColor="{AppThemeBinding Light=White, Dark=#181C24}" WidthRequest="54" HeightRequest="54">
                            <Path Data="M12,4V14M12,14L8,10M12,14L16,10M6,18H18" Stroke="#D31963" StrokeThickness="2" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Border Grid.Column="1" Stroke="{AppThemeBinding Light=#E3E4E8, Dark=#2A2F3A}" StrokeThickness="1" StrokeShape="RoundRectangle 27" BackgroundColor="{AppThemeBinding Light=White, Dark=#181C24}" WidthRequest="54" HeightRequest="54">
                            <Path Data="M12,20V10M12,10L8,14M12,10L16,14M6,6H18" Stroke="#D31963" StrokeThickness="2" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Border Grid.Column="2" Stroke="#1C6272" StrokeThickness="2" StrokeShape="RoundRectangle 27" Padding="14,0" HeightRequest="54">
                            <Label Text="Preview" TextColor="#1C6272" FontSize="16" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Border>
                        <Border Grid.Column="3" Stroke="#D31963" StrokeThickness="2" StrokeShape="RoundRectangle 27" Padding="12,0" HeightRequest="54">
                            <Label Text="EN ▾" TextColor="#D31963" FontSize="16" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*" Margin="0,4,0,0">
                        <Label Text="Description" TextColor="#D31963" FontSize="16" HorizontalTextAlignment="Center" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="Stories (20)" TextColor="{AppThemeBinding Light=#94959B, Dark=#AEB7CA}" FontSize="16" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="2" Text="Reviews" TextColor="{AppThemeBinding Light=#94959B, Dark=#AEB7CA}" FontSize="16" HorizontalTextAlignment="Center" />
                    </Grid>
                    <BoxView HeightRequest="2" WidthRequest="122" Color="#D31963" HorizontalOptions="Start" />
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E7E8EC, Dark=#2A2F3A}" Margin="0,-10,0,0" />

                    <Label FontSize="16">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Provided by " TextColor="{AppThemeBinding Light=#2B2D33, Dark=#EEF1F8}" />
                                <Span Text="{Binding ProviderName}" TextColor="#1C6272" TextDecorations="Underline" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                    <Label Text="{Binding Description}" FontSize="16" TextColor="{AppThemeBinding Light=#2B2D33, Dark=#D7DEEC}" LineBreakMode="WordWrap" />

                    <Label Text="{Binding Credit}" FontSize="14" TextColor="#2D89C8" TextDecorations="Underline" LineBreakMode="WordWrap" />

                    <Border Stroke="{AppThemeBinding Light=#E3E7EE, Dark=#2A2F3A}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#181C24}"
                            Padding="14">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Text to Speech" FontSize="16" FontAttributes="Bold" TextColor="#D31963" />
                            <Editor Text="{Binding SpeechTextInput}"
                                    AutoSize="TextChanges"
                                    Placeholder="Nhập nội dung sẽ được đọc khi phát audio..."
                                    BackgroundColor="Transparent"
                                    TextColor="{AppThemeBinding Light=#2B2D33, Dark=#EEF1F8}"
                                    HeightRequest="140" />
                            <Button Text="Lưu text TTS"
                                    Command="{Binding SaveSpeechTextCommand}"
                                    Style="{StaticResource PrimaryPillButtonStyle}"
                                    HeightRequest="52"
                                    CornerRadius="26"
                                    FontSize="18" />
                        </VerticalStackLayout>
                    </Border>

                    <Grid ColumnDefinitions="*" Margin="0,10,0,10">
                        <Button Text="View Tour"
                                Command="{Binding ViewTourCommand}"
                                Style="{StaticResource PrimaryPillButtonStyle}"
                                HeightRequest="58"
                                CornerRadius="28"
                                FontSize="20" />
                    </Grid>
                </VerticalStackLayout>
            </ScrollView>
        </Border>
    </Grid>
</ContentPage>
