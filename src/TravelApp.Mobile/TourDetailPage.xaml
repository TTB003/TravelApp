<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:TravelApp.Mobile.Services"
             x:Class="TravelApp.TourDetailPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource TravelPageLight}, Dark={StaticResource TravelPageDark}}">

    <Grid RowDefinitions="300,*">
        <Grid Grid.Row="0">
            <Image Source="{Binding Tour.ImageUrl}" Aspect="AspectFill" />

            <Grid Padding="18,52,18,0" ColumnDefinitions="56,*,56" VerticalOptions="Start">
                <Border BackgroundColor="#E31667" StrokeThickness="0" WidthRequest="56" HeightRequest="56" StrokeShape="RoundRectangle 28">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding BackCommand}" />
                    </Border.GestureRecognizers>
                    <Path Data="M15.4,4.6L14,3.2L5.2,12L14,20.8L15.4,19.4L8,12L15.4,4.6Z"
                          Fill="White"
                          WidthRequest="18"
                          HeightRequest="18"
                          HorizontalOptions="Center"
                          VerticalOptions="Center" />
                </Border>
                <Border x:Name="BookmarkButton"
                        Grid.Column="2"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1B1E25}"
                        Stroke="#E7D3DF"
                        StrokeThickness="1.2"
                        WidthRequest="56"
                        HeightRequest="56"
                        StrokeShape="RoundRectangle 28">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBookmarkTapped" />
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,*" Padding="0,5,0,3">
                        <Border Grid.Row="0"
                                HorizontalOptions="Center"
                                VerticalOptions="Start"
                                BackgroundColor="#E31667"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 10"
                                Padding="6,1"
                                IsVisible="{Binding IsBookmarked}">
                            <Label Text="{Binding SavedText, Source={x:Static services:LocalizationManager.Instance}}"
                                   FontSize="9"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalTextAlignment="Center" />
                        </Border>

                        <Grid Grid.Row="1" WidthRequest="24" HeightRequest="24" HorizontalOptions="Center" VerticalOptions="Center">
                            <Path Data="M6,5H18C18.55,5 19,5.45 19,6V18C19,18.55 18.55,19 18,19H6C5.45,19 5,18.55 5,18V6C5,5.45 5.45,5 6,5M7,7V17H17V7H7Z"
                                  Fill="Transparent"
                                  Stroke="#C2185B"
                                  StrokeThickness="1.9"
                                  WidthRequest="20"
                                  HeightRequest="20"
                                  HorizontalOptions="Center"
                                  VerticalOptions="Center" />
                            <Path Data="M6,5H18C18.55,5 19,5.45 19,6V18C19,18.55 18.55,19 18,19H6C5.45,19 5,18.55 5,18V6C5,5.45 5.45,5 6,5M7,7V17H17V7H7Z"
                                  Fill="#E31667"
                                  WidthRequest="20"
                                  HeightRequest="20"
                                  HorizontalOptions="Center"
                                  VerticalOptions="Center">
                                <Path.Triggers>
                                    <DataTrigger TargetType="Path" Binding="{Binding IsBookmarked}" Value="False">
                                        <Setter Property="Opacity" Value="0" />
                                    </DataTrigger>
                                </Path.Triggers>
                            </Path>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="1" BackgroundColor="{AppThemeBinding Light=#F6F6F8, Dark=#111318}" StrokeThickness="0" StrokeShape="RoundRectangle 0" Padding="18,18,18,12">
            <ScrollView>
                <VerticalStackLayout Spacing="0">

                    <Label Text="{Binding Tour.Title}" 
               FontSize="22" 
               FontAttributes="Bold" 
               TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" 
               Margin="0,0,0,4" />

                    <HorizontalStackLayout Spacing="4" Margin="0,0,0,4">
                        <Label Text="★" TextColor="#FADB14" FontSize="16" />
                        <Label Text="★" TextColor="#FADB14" FontSize="16" />
                        <Label Text="★" TextColor="#FADB14" FontSize="16" />
                        <Label Text="★" TextColor="#FADB14" FontSize="16" />
                        <Label Text="★" TextColor="#FADB14" FontSize="16" />
                    </HorizontalStackLayout>

                    <Label Text="{Binding Tour.Subtitle}" 
               FontSize="14" 
               TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" 
               Margin="0,0,0,16" />

                    <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" Margin="0,0,0,12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#0F5A6D" Offset="0.0" />
                                <GradientStop Color="#4B237F" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid RowDefinitions="Auto,Auto,Auto" Padding="16" RowSpacing="12">

                            <Grid ColumnDefinitions="*,Auto" Grid.Row="0">
                                <Label Text="{Binding AudioGuideText, Source={x:Static services:LocalizationManager.Instance}}" TextColor="White" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" />
                            </Grid>

                            <Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="16" VerticalOptions="Center">
                                <Border StrokeShape="RoundRectangle 24" WidthRequest="48" HeightRequest="48" BackgroundColor="#E31667" StrokeThickness="0">
                                    <Path Data="M8,5V19L19,12Z" Fill="White" WidthRequest="20" HeightRequest="20" HorizontalOptions="Center" VerticalOptions="Center" Margin="1,0,0,0" />
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding PlayAudioCommand}" />
                                    </Border.GestureRecognizers>
                                </Border>

                                <Slider Grid.Column="1" 
                            Minimum="0" Maximum="100" 
                            Value="{Binding PlayerProgress}" 
                            MinimumTrackColor="#E31667" 
                            MaximumTrackColor="#FFFFFF" 
                            ThumbColor="#E31667" 
                            VerticalOptions="Center" />
                            </Grid>

                            <!-- Transcript Area: Hiển thị nội dung đang đọc -->
                            <VerticalStackLayout Grid.Row="2" Spacing="4" IsVisible="{Binding IsPlaying}">
                                <BoxView HeightRequest="1" Color="White" Opacity="0.2" Margin="0,4" />
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="{Binding NowPlayingAudioText, Source={x:Static services:LocalizationManager.Instance}}" 
                                           TextColor="#FFC107" 
                                           FontSize="11" 
                                           FontAttributes="Bold" />
                                    <Label Text="{Binding SelectedSpeechLanguageDisplayText}" 
                                           TextColor="White" 
                                           FontSize="11" 
                                           Opacity="0.7" />
                                </HorizontalStackLayout>
                                <Label Text="{Binding CurrentPlayingText}" 
                                       TextColor="White" 
                                       FontSize="13" 
                                       LineBreakMode="WordWrap"
                                       Opacity="0.9"
                                       MaxLines="10" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <Button Text="{Binding ViewTourText, Source={x:Static services:LocalizationManager.Instance}}"
                            Command="{Binding ViewTourCommand}"
                            BackgroundColor="#E31667"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="25"
                            HeightRequest="50"
                            Margin="0,4,0,16"
                            CharacterSpacing="1" />
                    
                    <!-- Description block restored -->
                    <Label Text="{Binding Tour.Description}" 
                       FontSize="14" 
                       TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" 
                       Margin="0,0,0,16" 
                       LineBreakMode="WordWrap" />

                    <!-- Speech Text Editor (Chỉ hiển thị cho Owner) -->
                    <VerticalStackLayout Spacing="8" IsVisible="{Binding CanEditSpeechText}" Margin="0,0,0,24">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="{Binding EditSpeechTextOwnerText, Source={x:Static services:LocalizationManager.Instance}}" 
                                   FontSize="13" 
                                   FontAttributes="Bold" 
                                   TextColor="#E31667" 
                                   VerticalOptions="Center" />

                            <!-- Nút chọn ngôn ngữ để thêm/sửa -->
                            <Button Grid.Column="1"
                                    Text="{Binding SelectedSpeechLanguageDisplayText}"
                                    Command="{Binding ToggleSpeechLanguageMenuCommand}"
                                    FontSize="11"
                                    Padding="10,0"
                                    HeightRequest="30"
                                    BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2A2F3A}"
                                    TextColor="{AppThemeBinding Light=#E31667, Dark=White}"
                                    CornerRadius="15" />
                        </Grid>

                        <Label Text="{Binding ChooseLanguageDescText, Source={x:Static services:LocalizationManager.Instance}}" FontSize="11" TextColor="Gray" />
                        
                        <Border Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#2A2F3A}" 
                                StrokeThickness="1" 
                                StrokeShape="RoundRectangle 12" 
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#1B1E25}" 
                                Padding="12">
                            <Editor Text="{Binding SpeechTextInput}"
                                    Unfocused="OnSpeechTextEditorUnfocused"
                                    AutoSize="TextChanges"
                                    Placeholder="{Binding SpeechTextPlaceholderText, Source={x:Static services:LocalizationManager.Instance}}"
                                    BackgroundColor="Transparent"
                                    TextColor="{AppThemeBinding Light=#2B2D33, Dark=#EEF1F8}"
                                    HeightRequest="140" />
                        </Border>

                        <Grid ColumnDefinitions="*, Auto">
                            <Button Text="{Binding SaveContentText, Source={x:Static services:LocalizationManager.Instance}}" 
                                    Command="{Binding SaveSpeechTextCommand}"
                                    BackgroundColor="#E31667"
                                    TextColor="White"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    HeightRequest="40"
                                    Padding="20,0"
                                    CornerRadius="20"
                                    HorizontalOptions="Start" />
                            
                            <HorizontalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center" IsVisible="{Binding IsSavingSpeechText}">
                                <ActivityIndicator IsRunning="True" HeightRequest="14" WidthRequest="14" Color="#E31667" />
                                <Label Text="{Binding SavingText, Source={x:Static services:LocalizationManager.Instance}}" FontSize="11" TextColor="#E31667" />
                            </HorizontalStackLayout>
                        </Grid>
                    </VerticalStackLayout>

                    <Border Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#2A2F3A}" 
                StrokeThickness="1" 
                StrokeShape="RoundRectangle 16" 
                BackgroundColor="{AppThemeBinding Light=White, Dark=#181C24}" 
                Padding="16,24" 
                Margin="0,0,0,24">
                        <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                            <Label Text="{Binding ScanToShareText, Source={x:Static services:LocalizationManager.Instance}}" 
                       FontSize="13" 
                       FontAttributes="Bold" 
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" 
                       HorizontalTextAlignment="Center" />

                            <Image Source="{Binding Tour.QrImageUrl}" 
                       WidthRequest="160" 
                       HeightRequest="160" 
                       Aspect="AspectFit" 
                       HorizontalOptions="Center" />

                            <Label Text="{Binding OrScanOtherPoisText, Source={x:Static services:LocalizationManager.Instance}}" 
                       FontSize="12" 
                       TextColor="Gray" 
                       HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>
        </Border>

        <Grid Grid.RowSpan="2" IsVisible="{Binding IsSpeechLanguageMenuOpen}" InputTransparent="False">
            <BoxView Color="#77000000" />
            <Border VerticalOptions="Start"
                    Margin="0,120,0,0"
                    BackgroundColor="#212121"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24,24,0,0"
                    Padding="0,14,0,20">
                <ScrollView>
                    <VerticalStackLayout Padding="16,0" Spacing="12">
                        <Grid ColumnDefinitions="*,Auto" Padding="8,0,8,0">
                            <Label Text="{Binding ChooseTtsLanguageText, Source={x:Static services:LocalizationManager.Instance}}" FontSize="22" FontAttributes="Bold" TextColor="White" />
                            <Button Grid.Column="1"
                                    Text="✕"
                                    Command="{Binding CloseSpeechLanguageMenuCommand}"
                                    FontSize="22"
                                    TextColor="White"
                                    BackgroundColor="Transparent"
                                    Padding="0" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="#2A2F3A" />

                        <CollectionView ItemsSource="{Binding SpeechLanguages}" SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Stroke="#303746"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 16"
                                            BackgroundColor="#2A2F3A"
                                            Padding="14,12">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectSpeechLanguageCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BackgroundColor" Value="#374151" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Text="{Binding DisplayName}" FontSize="16" TextColor="White" />
                                            <Label Grid.Column="1" Text="✓" TextColor="#00CED1" FontSize="18">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="False">
                                                        <Setter Property="Text" Value="" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
