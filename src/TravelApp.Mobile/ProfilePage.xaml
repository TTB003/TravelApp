<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:TravelApp"
             x:Class="TravelApp.ProfilePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource TravelPageLight}, Dark={StaticResource TravelPageDark}}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <local:LangToBackgroundConverter x:Key="LangToBackgroundConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <Grid BackgroundColor="#E31667" Padding="16,48,16,16" ColumnDefinitions="40,*,40">
            <Border WidthRequest="40"
                    HeightRequest="40"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20"
                    BackgroundColor="#33FFFFFF">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding BackCommand}" />
                </Border.GestureRecognizers>
                <Path Data="M15.4,4.6L14,3.2L5.2,12L14,20.8L15.4,19.4L8,12L15.4,4.6Z"
                      Fill="White"
                      WidthRequest="16"
                      HeightRequest="16"
                      HorizontalOptions="Center"
                      VerticalOptions="Center" />
            </Border>

            <Label Grid.Column="1"
                   Text="Profile"
                   TextColor="White"
                   FontAttributes="Bold"
                   FontSize="30"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,18,18,26" Spacing="18">
                <Border Stroke="{AppThemeBinding Light=#E6E6EA, Dark=#2A2F3A}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#181C24}"
                        Padding="14">
                    <Grid ColumnDefinitions="66,*" ColumnSpacing="12">
                        <Border Stroke="{AppThemeBinding Light=#ECECEF, Dark=#2A2F3A}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 33"
                                WidthRequest="66"
                                HeightRequest="66"
                                BackgroundColor="{AppThemeBinding Light=#FAFAFB, Dark=#202635}">
                            <Label Text="👤"
                                   FontSize="30"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding GreetingTitle}"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#1B1C22, Dark=#EEF1F8}" />
                            <Label Text="{Binding GreetingSubtitle}"
                                   FontSize="17"
                                   TextColor="{AppThemeBinding Light=#4D4D57, Dark=#B4BDCF}" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <VerticalStackLayout IsVisible="{Binding ShowAccountSection}" Spacing="10">
                    <Label Text="My Account"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#0D5B6C, Dark=#7ECFE3}" />

                    <Border Stroke="{AppThemeBinding Light=#ECECF1, Dark=#2A2F3A}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#181C24}"
                            Padding="14,6">
                        <VerticalStackLayout Spacing="0">
                            <Grid ColumnDefinitions="40,*,Auto" HeightRequest="58" ColumnSpacing="12">
                                <Border WidthRequest="32"
                                        HeightRequest="32"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 16"
                                        BackgroundColor="#FFF2F7"
                                        VerticalOptions="Center">
                                    <Label Text="👤" FontSize="16" TextColor="#D31963" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                </Border>
                                <Label Grid.Column="1" Text="Edit Profile" FontSize="20" TextColor="{AppThemeBinding Light=#1F1F24, Dark=#E6EBF7}" VerticalTextAlignment="Center" />
                                <Label Grid.Column="2" Text="›" FontSize="26" TextColor="{AppThemeBinding Light=#9A9AA2, Dark=#9AA4B8}" VerticalTextAlignment="Center" />
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding OpenEditProfileCommand}" />
                                </Grid.GestureRecognizers>
                            </Grid>

                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#F0F0F3, Dark=#2A2F3A}" IsVisible="{Binding ShowPurchases}" />

                            <Grid ColumnDefinitions="40,*,Auto" HeightRequest="58" IsVisible="{Binding ShowPurchases}" ColumnSpacing="12">
                                <Border WidthRequest="32"
                                        HeightRequest="32"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 16"
                                        BackgroundColor="#FFF2F7"
                                        VerticalOptions="Center">
                                    <Label Text="↓" FontSize="18" TextColor="#D31963" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontAttributes="Bold" />
                                </Border>
                                <Label Grid.Column="1" Text="Downloads" FontSize="20" TextColor="{AppThemeBinding Light=#1F1F24, Dark=#E6EBF7}" VerticalTextAlignment="Center" />
                                <Label Grid.Column="2" Text="›" FontSize="26" TextColor="{AppThemeBinding Light=#9A9AA2, Dark=#9AA4B8}" VerticalTextAlignment="Center" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10">
                    <Label Text="Preferences"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#0D5B6C, Dark=#7ECFE3}" />

                    <Border Stroke="{AppThemeBinding Light=#ECECF1, Dark=#2A2F3A}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#181C24}"
                            Padding="14,6">
                        <VerticalStackLayout Spacing="0">
                            <Grid ColumnDefinitions="40,*,Auto" HeightRequest="58" ColumnSpacing="12">
                                <Border WidthRequest="32"
                                        HeightRequest="32"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 16"
                                        BackgroundColor="#EEF8FB"
                                        VerticalOptions="Center">
                                    <Label Text="🌐" FontSize="18" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                </Border>
                                <Label Grid.Column="1" Text="Language" FontSize="20" TextColor="{AppThemeBinding Light=#1F1F24, Dark=#E6EBF7}" VerticalTextAlignment="Center" />
                                
                                <HorizontalStackLayout Grid.Column="2" Spacing="6" VerticalOptions="Center" Margin="0,0,4,0">
                                    <Button Text="VI" 
                                            FontSize="11"
                                            FontAttributes="Bold"
                                            HeightRequest="32"
                                            WidthRequest="42"
                                            Padding="0"
                                            CornerRadius="16"
                                            BackgroundColor="{Binding BindingContext.CurrentLanguage, Source={RelativeSource AncestorType={x:Type local:ProfilePage}}, Converter={StaticResource LangToBackgroundConverter}, ConverterParameter='vi-VN'}"
                                            TextColor="White"
                                            Command="{Binding ChangeLanguageCommand}"
                                            CommandParameter="vi-VN" />
                                    <Button Text="EN" 
                                            FontSize="11"
                                            FontAttributes="Bold"
                                            HeightRequest="32"
                                            WidthRequest="42"
                                            Padding="0"
                                            CornerRadius="16"
                                            BackgroundColor="{Binding BindingContext.CurrentLanguage, Source={RelativeSource AncestorType={x:Type local:ProfilePage}}, Converter={StaticResource LangToBackgroundConverter}, ConverterParameter='en-US'}"
                                            TextColor="White"
                                            Command="{Binding ChangeLanguageCommand}"
                                            CommandParameter="en-US" />
                                </HorizontalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#F0F0F3, Dark=#2A2F3A}" />

                            <Grid ColumnDefinitions="40,*,Auto" HeightRequest="58" ColumnSpacing="12">
                                <Border WidthRequest="32"
                                        HeightRequest="32"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 16"
                                        BackgroundColor="#EEF8FB"
                                        VerticalOptions="Center">
                                    <Label Text="⚙" FontSize="16" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                </Border>
                                <Label Grid.Column="1" Text="User preferences" FontSize="20" TextColor="{AppThemeBinding Light=#1F1F24, Dark=#E6EBF7}" VerticalTextAlignment="Center" />
                                <Label Grid.Column="2" Text="›" FontSize="26" TextColor="{AppThemeBinding Light=#9A9AA2, Dark=#9AA4B8}" VerticalTextAlignment="Center" />
                            </Grid>

                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#F0F0F3, Dark=#2A2F3A}" IsVisible="{Binding ShowDownloads}" />

                            <Grid ColumnDefinitions="40,*,Auto" HeightRequest="58" IsVisible="{Binding ShowDownloads}" ColumnSpacing="12">
                                <Border WidthRequest="32"
                                        HeightRequest="32"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 16"
                                        BackgroundColor="#FFF2F7"
                                        VerticalOptions="Center">
                                    <Label Text="↓" FontSize="18" TextColor="#D31963" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontAttributes="Bold" />
                                </Border>
                                <Label Grid.Column="1" Text="{Binding DownloadsTitle}" FontSize="20" TextColor="{AppThemeBinding Light=#1F1F24, Dark=#E6EBF7}" VerticalTextAlignment="Center" />
                                <Label Grid.Column="2" Text="›" FontSize="26" TextColor="{AppThemeBinding Light=#9A9AA2, Dark=#9AA4B8}" VerticalTextAlignment="Center" />
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding OpenDownloadsCommand}" />
                                </Grid.GestureRecognizers>
                            </Grid>

                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#F0F0F3, Dark=#2A2F3A}" IsVisible="{Binding ShowBookmarks}" />

                            <Grid ColumnDefinitions="40,*,Auto" HeightRequest="58" IsVisible="{Binding ShowBookmarks}" ColumnSpacing="12">
                                <Border WidthRequest="32"
                                        HeightRequest="32"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 16"
                                        BackgroundColor="#FFF2F7"
                                        VerticalOptions="Center">
                                    <Label Text="▮" FontSize="16" TextColor="#D31963" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontAttributes="Bold" />
                                </Border>
                                <Label Grid.Column="1" Text="Bookmarks" FontSize="20" TextColor="{AppThemeBinding Light=#1F1F24, Dark=#E6EBF7}" VerticalTextAlignment="Center" />
                                <Label Grid.Column="2" Text="›" FontSize="26" TextColor="{AppThemeBinding Light=#9A9AA2, Dark=#9AA4B8}" VerticalTextAlignment="Center" />
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding OpenBookmarksCommand}" />
                                </Grid.GestureRecognizers>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10">
                    <Label Text="Backup &amp; Restore"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#0D5B6C, Dark=#7ECFE3}" />

                    <Border Stroke="{AppThemeBinding Light=#ECECF1, Dark=#2A2F3A}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#181C24}"
                            Padding="14,12">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Export ra file SQLite để copy sang máy khác hoặc lưu backup. Import sẽ nạp lại file .db3 hiện có."
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#4D4D57, Dark=#B4BDCF}" />

                            <HorizontalStackLayout Spacing="10">
                                <Button Text="Export database"
                                        Command="{Binding ExportDatabaseCommand}"
                                        BackgroundColor="#E31667"
                                        TextColor="White"
                                        CornerRadius="16"
                                        HorizontalOptions="FillAndExpand" />

                                <Button Text="Import database"
                                        Command="{Binding ImportDatabaseCommand}"
                                        BackgroundColor="{AppThemeBinding Light=#EEF2F8, Dark=#202635}"
                                        TextColor="{AppThemeBinding Light=#1B1C22, Dark=#EEF1F8}"
                                        CornerRadius="16"
                                        HorizontalOptions="FillAndExpand" />
                            </HorizontalStackLayout>

                            <Label Text="{Binding BackupStatus}"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#6E7380, Dark=#B4BDCF}"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <Button Text="{Binding PrimaryActionText}"
                        Command="{Binding PrimaryActionCommand}"
                        Style="{StaticResource PrimaryPillButtonStyle}"
                        Margin="0,10,0,0" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
