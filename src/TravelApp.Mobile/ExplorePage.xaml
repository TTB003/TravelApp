<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
           xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:TravelApp"
             xmlns:services="clr-namespace:TravelApp.Mobile.Services"
             x:Class="TravelApp.ExplorePage"
             BackgroundColor="{AppThemeBinding Light={StaticResource TravelPageLight}, Dark={StaticResource TravelPageDark}}"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <Color x:Key="PrimaryAccent">#C2185B</Color>
        <Color x:Key="SecondaryText">#6E7380</Color>
        <Color x:Key="CardBorder">#E8EBF2</Color>
        <Color x:Key="DarkSecondaryText">#A7AEBD</Color>
        <Color x:Key="DarkCardBorder">#2A2F3A</Color>
        <Color x:Key="DarkCardBackground">#181C24</Color>
        <Color x:Key="DarkTitleText">#EEF1F8</Color>

        <Style x:Key="SectionTitleStyle" TargetType="Label">
            <Setter Property="FontSize" Value="19" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#14161D, Dark={StaticResource DarkTitleText}}" />
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="Label">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#161922, Dark={StaticResource DarkTitleText}}" />
            <Setter Property="LineBreakMode" Value="TailTruncation" />
        </Style>

        <Style x:Key="CardSubTitleStyle" TargetType="Label">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#6E7380, Dark={StaticResource DarkSecondaryText}}" />
            <Setter Property="LineBreakMode" Value="TailTruncation" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="120,*,84">

        <!-- Header -->
        <Grid Grid.Row="0">
            <Image Source="https://images.unsplash.com/photo-1480714378408-67cf0d13bc1f?w=1200&amp;h=500&amp;fit=crop"
                   Aspect="AspectFill" />
            <Border StrokeThickness="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0E8AA8" Offset="0" />
                        <GradientStop Color="#1B5D9A" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Grid Padding="14,48,14,14" ColumnDefinitions="40,*,40,40" ColumnSpacing="10">
                <Border Grid.Column="0"
                        WidthRequest="40"
                        HeightRequest="40"
                        StrokeThickness="0"
                        BackgroundColor="#33FFFFFF"
                        StrokeShape="RoundRectangle 20"
                        AutomationProperties.Name="Open navigation menu"
                        VerticalOptions="Center"
                        HorizontalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleMenuCommand}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="3"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center">
                        <Border StrokeThickness="0" BackgroundColor="White" WidthRequest="14" HeightRequest="2" StrokeShape="RoundRectangle 1" />
                        <Border StrokeThickness="0" BackgroundColor="White" WidthRequest="14" HeightRequest="2" StrokeShape="RoundRectangle 1" />
                        <Border StrokeThickness="0" BackgroundColor="White" WidthRequest="14" HeightRequest="2" StrokeShape="RoundRectangle 1" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        StrokeShape="RoundRectangle 22"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#202635}"
                        Padding="14,0,4,0"
                        HeightRequest="48"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenSearchCommand}" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,40" ColumnSpacing="0">
                        <Label Text="{Binding SearchPlaceholder, Source={x:Static services:LocalizationManager.Instance}}"
                               TextColor="{AppThemeBinding Light=#5D6D79, Dark=#B4BDCF}"
                               FontSize="14"
                               VerticalTextAlignment="Center" />

                        <Border Grid.Column="1"
                                StrokeThickness="0"
                                BackgroundColor="#D61B63"
                                StrokeShape="RoundRectangle 20"
                                WidthRequest="40"
                                HeightRequest="40"
                                HorizontalOptions="End"
                                VerticalOptions="Center">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenSearchCommand}" />
                            </Border.GestureRecognizers>
                            <Path Data="M15.5,14H14.71L14.43,13.73C15.41,12.59 16,11.11 16,9.5C16,5.91 13.09,3 9.5,3C5.91,3 3,5.91 3,9.5C3,13.09 5.91,16 9.5,16C11.11,16 12.59,15.41 13.73,14.43L14,14.71V15.5L19,20.49L20.49,19L15.5,14M9.5,14C7.01,14 5,11.99 5,9.5C5,7.01 7.01,5 9.5,5C11.99,5 14,7.01 14,9.5C14,11.99 11.99,14 9.5,14Z"
                                  Fill="White"
                                  WidthRequest="17"
                                  HeightRequest="17"
                                  Aspect="Uniform"
                                  HorizontalOptions="Center"
                                  VerticalOptions="Center" />
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        StrokeThickness="0"
                        BackgroundColor="#33FFFFFF"
                        StrokeShape="RoundRectangle 20"
                        WidthRequest="40"
                        HeightRequest="40"
                        AutomationProperties.Name="Scan QR code"
                        VerticalOptions="Center"
                        HorizontalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenQrScannerCommand}" />
                    </Border.GestureRecognizers>
                    <Image Source="qr_icon.png" 
                           WidthRequest="24" 
                           HeightRequest="24" 
                           Aspect="AspectFit"
                           HorizontalOptions="Center" 
                           VerticalOptions="Center" />
                </Border>

                <Border Grid.Column="3"
                        StrokeThickness="0"
                        BackgroundColor="#33FFFFFF"
                        StrokeShape="RoundRectangle 20"
                        WidthRequest="40"
                        HeightRequest="40"
                        AutomationProperties.Name="Change Language"
                        VerticalOptions="Center"
                        HorizontalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ChangeLanguageCommand, Source={x:Static services:LocalizationManager.Instance}}" />
                    </Border.GestureRecognizers>
                    <Label Text="{Binding CurrentLanguageFlag, Source={x:Static services:LocalizationManager.Instance}}"
                           FontSize="20"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </Border>
            </Grid>
        </Grid>

        <!-- Body -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="14,14,14,8" Spacing="14">

                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12" VerticalOptions="Center">
                    <Label Text="{Binding AroundMeText, Source={x:Static services:LocalizationManager.Instance}}" Style="{StaticResource SectionTitleStyle}" />

                    <Border Grid.Column="1"
                            StrokeThickness="0"
                            BackgroundColor="Transparent"
                            Padding="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenMapCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="{Binding PoiMapText, Source={x:Static services:LocalizationManager.Instance}}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryAccent}"
                               VerticalTextAlignment="Center"
                               Padding="0,8" />
                    </Border>

                    <Border Grid.Column="2"
                            StrokeThickness="0"
                            BackgroundColor="Transparent"
                            Padding="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenTourMapRouteCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="{Binding MapViewText, Source={x:Static services:LocalizationManager.Instance}}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryAccent}"
                               VerticalTextAlignment="Center"
                               Padding="0,8" />
                    </Border>
                </Grid>

                <Border BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource DarkCardBackground}}"
                        Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource DarkCardBorder}}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        HeightRequest="230">
                    <Grid x:Name="ExploreMapContainer" />
                </Border>

                <Border x:Name="AudioStatusBorder"
                        IsVisible="{Binding IsAudioPlayingBarVisible}"
                        StrokeThickness="0"
                        BackgroundColor="#1E8E68"
                        StrokeShape="RoundRectangle 14"
                        Padding="12,10"
                        Margin="0,2,0,2">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenNowPlayingCommand}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="2">
                        <Label x:Name="AudioPoiTitleLabel"
                               Text="{Binding AudioPoiTitle}"
                          
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="White" />
                        <Label x:Name="AudioStatusTextLabel"
                               Text="{Binding NowPlayingAudioText, Source={x:Static services:LocalizationManager.Instance}}"
                               FontSize="13"
                               TextColor="#E6FFF7"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>
                </Border>

                <!-- New Trending Section -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,5">
                    <Label Text="{Binding TrendingTitle, Source={x:Static services:LocalizationManager.Instance}}" Style="{StaticResource SectionTitleStyle}" />
                </Grid>

                <CollectionView ItemsSource="{Binding ForYouItems}" HeightRequest="120">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border WidthRequest="220"
                                    Padding="10"
                                    StrokeShape="RoundRectangle 16"
                                    BackgroundColor="{AppThemeBinding Light=#F8F9FB, Dark=#1E232E}"
                                    StrokeThickness="0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenTourDetailCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="70,*" ColumnSpacing="10">
                                    <Border Grid.Column="0" StrokeShape="RoundRectangle 10" StrokeThickness="0">
                                        <Image Source="{Binding ImageUrl}" Aspect="AspectFill" HeightRequest="70" WidthRequest="70" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding Title}" 
                                               FontSize="14" 
                                               FontAttributes="Bold" 
                                               MaxLines="1" 
                                               LineBreakMode="TailTruncation" />
                                        <Border BackgroundColor="#FFE0E0" Padding="6,2" HorizontalOptions="Start" StrokeShape="RoundRectangle 4" StrokeThickness="0">
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="🔥" FontSize="10" VerticalTextAlignment="Center"/>
                                                <Label Text="{Binding PopularNowText, Source={x:Static services:LocalizationManager.Instance}}" FontSize="10" FontAttributes="Bold" TextColor="#D32F2F" VerticalTextAlignment="Center"/>
                                            </HorizontalStackLayout>
                                        </Border>
                                        <Label Text="{Binding Location}" 
                                               FontSize="11" 
                                               TextColor="#8C93A5" 
                                               MaxLines="1" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" VerticalOptions="Center" Margin="0,12,0,8">
                    <Label Text="{Binding HcmFoodTourText, Source={x:Static services:LocalizationManager.Instance}}" Style="{StaticResource SectionTitleStyle}" />
                    <Label Grid.Column="1"
                           Text="{Binding FeaturedText, Source={x:Static services:LocalizationManager.Instance}}"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="#FF9800"
                           VerticalTextAlignment="Center"
                           Padding="8,4" />
                </Grid>

                <CollectionView x:Name="ForYouCollection" ItemsSource="{Binding ForYouItems}" HeightRequest="290" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border WidthRequest="{OnIdiom Phone=312, Tablet=360, Desktop=400}"
                                    Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource DarkCardBorder}}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 24"
                                    BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource DarkCardBackground}}"
                                    Margin="0,2,0,2">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenTourDetailCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid RowDefinitions="165,*">
                                    <Grid Grid.Row="0">
                                        <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />

                                        <Border Margin="0,12,12,0"
                                                HorizontalOptions="End"
                                                VerticalOptions="Start"
                                                StrokeThickness="0"
                                                BackgroundColor="{AppThemeBinding Light=#F2F4F8, Dark=#2B3243}"
                                                StrokeShape="RoundRectangle 20"
                                                WidthRequest="40"
                                                HeightRequest="40">
                                            <Path Data="M12,4 L20,12 L16.8,12 L16.8,20 L7.2,20 L7.2,12 L4,12 Z"
                                                  Fill="#C2185B"
                                                  WidthRequest="14"
                                                  HeightRequest="14"
                                                  HorizontalOptions="Center"
                                                  VerticalOptions="Center"
                                                  Aspect="Uniform" />
                                        </Border>

                                        <Border Margin="12,0,0,12"
                                                VerticalOptions="End"
                                                HorizontalOptions="Start"
                                                StrokeThickness="0"
                                                BackgroundColor="{AppThemeBinding Light=#F8FAFF, Dark=#242C3B}"
                                                StrokeShape="RoundRectangle 16"
                                                Padding="12,6">
                                            <Label Text="~ m  |  ~ min"
                                                   FontSize="12"
                                                   TextColor="{AppThemeBinding Light=#7A7A84, Dark=#C0C6D4}" />
                                        </Border>
                                    </Grid>

                                    <Grid Grid.Row="1"
                                          Padding="14,10,14,12"
                                          RowDefinitions="Auto,Auto,Auto,Auto"
                                          ColumnDefinitions="*">
                                        <Label Text="{Binding Title}" Style="{StaticResource CardTitleStyle}" />
                                        <Label Grid.Row="1" Text="{Binding Subtitle}" Style="{StaticResource CardSubTitleStyle}" />

                                        <!-- Duration + Distance -->
                                        <HorizontalStackLayout Grid.Row="2" Spacing="12" VerticalOptions="Center" Margin="0,6,0,0">
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="⏱️" FontSize="12" VerticalTextAlignment="Center" />
                                                <Label Text="{Binding Duration}" FontSize="12" TextColor="{AppThemeBinding Light=#6E7380, Dark=#C5CBD9}" VerticalTextAlignment="Center" />
                                            </HorizontalStackLayout>
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="🎯" FontSize="12" VerticalTextAlignment="Center" />
                                                <Label Text="{Binding Distance}" FontSize="12" TextColor="{AppThemeBinding Light=#6E7380, Dark=#C5CBD9}" VerticalTextAlignment="Center" />
                                            </HorizontalStackLayout>
                                        </HorizontalStackLayout>

                                        <!-- Location -->
                                        <HorizontalStackLayout Grid.Row="3" Spacing="5" Margin="0,6,0,0">
                                            <Label Text="📍" FontSize="12" VerticalTextAlignment="Start" />
                                            <Label Text="{Binding Location}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource SecondaryText}, Dark={StaticResource DarkSecondaryText}}" LineBreakMode="TailTruncation" />
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="{Binding HanoiFoodTourText, Source={x:Static services:LocalizationManager.Instance}}" Style="{StaticResource SectionTitleStyle}" Margin="0,12,0,8" />

                <CollectionView x:Name="EditorsChoiceCollection" ItemsSource="{Binding EditorsChoiceItems}" HeightRequest="260" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border WidthRequest="{OnIdiom Phone=312, Tablet=360, Desktop=400}"
                                    Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource DarkCardBorder}}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 24"
                                    BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource DarkCardBackground}}"
                                    Margin="0,2,0,2">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenTourDetailCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid RowDefinitions="165,*">
                                    <Grid Grid.Row="0">
                                        <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                        <Border Margin="0,12,12,0"
                                                HorizontalOptions="End"
                                                VerticalOptions="Start"
                                                StrokeThickness="0"
                                                BackgroundColor="{AppThemeBinding Light=#F2F4F8, Dark=#2B3243}"
                                                StrokeShape="RoundRectangle 20"
                                                WidthRequest="40"
                                                HeightRequest="40">
                                            <Path Data="M12,4 L20,12 L16.8,12 L16.8,20 L7.2,20 L7.2,12 L4,12 Z"
                                                  Fill="#C2185B"
                                                  WidthRequest="14"
                                                  HeightRequest="14"
                                                  HorizontalOptions="Center"
                                                  VerticalOptions="Center"
                                                  Aspect="Uniform" />
                                        </Border>
                                    </Grid>

                                    <Grid Grid.Row="1" Padding="14,10,14,12" RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*">
                                        <Label Text="{Binding Title}" Style="{StaticResource CardTitleStyle}" />
                                        <Label Grid.Row="1" Text="{Binding Subtitle}" Style="{StaticResource CardSubTitleStyle}" />

                                        <!-- Duration + Distance -->
                                        <HorizontalStackLayout Grid.Row="2" Spacing="12" VerticalOptions="Center" Margin="0,6,0,0">
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="⏱️" FontSize="12" VerticalTextAlignment="Center" />
                                                <Label Text="{Binding Duration}" FontSize="12" TextColor="{AppThemeBinding Light=#6E7380, Dark=#C5CBD9}" VerticalTextAlignment="Center" />
                                            </HorizontalStackLayout>
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="🎯" FontSize="12" VerticalTextAlignment="Center" />
                                                <Label Text="{Binding Distance}" FontSize="12" TextColor="{AppThemeBinding Light=#6E7380, Dark=#C5CBD9}" VerticalTextAlignment="Center" />
                                            </HorizontalStackLayout>
                                        </HorizontalStackLayout>

                                        <!-- Location -->
                                        <HorizontalStackLayout Grid.Row="3" Spacing="5" Margin="0,6,0,0">
                                            <Label Text="📍" FontSize="12" VerticalTextAlignment="Start" />
                                            <Label Text="{Binding Location}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource SecondaryText}, Dark={StaticResource DarkSecondaryText}}" LineBreakMode="TailTruncation" />
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <BoxView HeightRequest="6" Color="Transparent" />
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.RowSpan="2"
              IsVisible="{Binding IsDiscoverTabActive}"
              InputTransparent="False"
              BackgroundColor="{AppThemeBinding Light={StaticResource TravelPageLight}, Dark={StaticResource TravelPageDark}}"
              ZIndex="10">
            <Grid RowDefinitions="Auto,*">
                <Grid BackgroundColor="#0F627D" Padding="14,48,14,14" ColumnDefinitions="40,*,40">
                    <Border WidthRequest="40"
                            HeightRequest="40"
                            StrokeThickness="0"
                            BackgroundColor="#33FFFFFF"
                            StrokeShape="RoundRectangle 20">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectBottomTabCommand}" CommandParameter="Explore" />
                        </Border.GestureRecognizers>
                        <Path Data="M15.4,4.6L14,3.2L5.2,12L14,20.8L15.4,19.4L8,12L15.4,4.6Z"
                              Fill="White"
                              WidthRequest="16"
                              HeightRequest="16"
                              HorizontalOptions="Center"
                              VerticalOptions="Center" />
                    </Border>

                    <Label Grid.Column="1"
                           Text="{Binding NoStoriesText, Source={x:Static services:LocalizationManager.Instance}}"
                           TextColor="White"
                           FontSize="20"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />

                    <Border Grid.Column="2"
                            WidthRequest="40"
                            HeightRequest="40"
                            StrokeThickness="0"
                            BackgroundColor="#33FFFFFF"
                            StrokeShape="RoundRectangle 20">
                        <Label Text="i"
                               TextColor="White"
                               FontSize="22"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Border>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid x:Name="DiscoverMapContainer" />

                    <VerticalStackLayout Spacing="10"
                                         HorizontalOptions="End"
                                         VerticalOptions="Start"
                                         Margin="0,16,16,0">
                        <Border WidthRequest="48" HeightRequest="48" BackgroundColor="#AA4D535C" StrokeThickness="0" StrokeShape="RoundRectangle 24">
                            <Label Text="◈" TextColor="White" FontSize="22" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Border>
                        <Border WidthRequest="48" HeightRequest="48" BackgroundColor="#AA4D535C" StrokeThickness="0" StrokeShape="RoundRectangle 24">
                            <Label Text="◎" TextColor="White" FontSize="22" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Border>
                    </VerticalStackLayout>

                    <Border HorizontalOptions="Center"
                            VerticalOptions="End"
                            Margin="0,0,0,26"
                            WidthRequest="180"
                            HeightRequest="52"
                            StrokeThickness="0"
                            BackgroundColor="{StaticResource TravelAccent}"
                            StrokeShape="RoundRectangle 26">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenMapCommand}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*,Auto" Padding="0,0,18,0">
                            <Label Text="{Binding StartText, Source={x:Static services:LocalizationManager.Instance}}"
                                   TextColor="White"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                            <Label Grid.Column="1"
                                   Text="▶"
                                   TextColor="White"
                                   FontSize="18"
                                   VerticalTextAlignment="Center" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- Bottom Nav -->
        <Border Grid.Row="2"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#171B23}"
                StrokeShape="RoundRectangle 30,30,0,0"
                Padding="14,10,14,12">
            <Grid ColumnDefinitions="*,*,*,*,*" VerticalOptions="Center">

                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Border WidthRequest="52" HeightRequest="52" StrokeThickness="0" StrokeShape="RoundRectangle 26" BackgroundColor="{AppThemeBinding Light=#F3F4F8, Dark=#202635}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectBottomTabCommand}" CommandParameter="Explore" />
                        </Border.GestureRecognizers>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsExploreTabActive}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource TravelAccent}" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Path Data="M12,4A8,8 0 1,0 12,20A8,8 0 1,0 12,4M12,6A6,6 0 1,1 12,18A6,6 0 1,1 12,6M9,15L11,10L15,8L13,13L9,15Z"
                              Fill="{AppThemeBinding Light=#8C93A5, Dark=#A7AEBD}"
                              WidthRequest="24"
                              HeightRequest="24"
                              HorizontalOptions="Center"
                              VerticalOptions="Center">
                            <Path.Triggers>
                                <DataTrigger TargetType="Path" Binding="{Binding IsExploreTabActive}" Value="True">
                                    <Setter Property="Fill" Value="White" />
                                </DataTrigger>
                            </Path.Triggers>
                        </Path>
                    </Border>
                    <Label Text="Explore" FontSize="12" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light=#8C8C97, Dark=#9AA4B8}" IsVisible="False">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsExploreTabActive}" Value="True">
                                <Setter Property="IsVisible" Value="True" />
                                <Setter Property="TextColor" Value="{StaticResource TravelAccent}" />
                                <Setter Property="FontAttributes" Value="Bold" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="Center">
                    <Border WidthRequest="52" HeightRequest="52" StrokeThickness="0" StrokeShape="RoundRectangle 26" BackgroundColor="{AppThemeBinding Light=#F3F4F8, Dark=#202635}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectBottomTabCommand}" CommandParameter="Discover" />
                        </Border.GestureRecognizers>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsDiscoverTabActive}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource TravelAccent}" />
                            </DataTrigger>
                        </Border.Triggers>
