<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelApp.ProfilePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F4F4F6">

    <Grid RowDefinitions="Auto,*">
        <Grid BackgroundColor="#E31667" Padding="16,48,16,16" ColumnDefinitions="40,*,40">
            <Button Text="←"
                    Command="{Binding BackCommand}"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontSize="26"
                    Padding="0" />

            <Label Grid.Column="1"
                   Text="Profile"
                   TextColor="White"
                   FontAttributes="Bold"
                   FontSize="30"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,18,18,26" Spacing="18">
                <Border Stroke="#E6E6EA"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        BackgroundColor="White"
                        Padding="14">
                    <Grid ColumnDefinitions="66,*" ColumnSpacing="12">
                        <Border Stroke="#ECECEF"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 33"
                                WidthRequest="66"
                                HeightRequest="66"
                                BackgroundColor="#FAFAFB">
                            <Label Text="👤"
                                   FontSize="30"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding GreetingTitle}"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="#1B1C22" />
                            <Label Text="{Binding GreetingSubtitle}"
                                   FontSize="17"
                                   TextColor="#4D4D57" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <VerticalStackLayout IsVisible="{Binding ShowAccountSection}" Spacing="10">
                    <Label Text="My Account"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#0D5B6C" />

                    <Border Stroke="#ECECF1"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="White"
                            Padding="14,6">
                        <VerticalStackLayout Spacing="0">
                            <Grid ColumnDefinitions="Auto,*,Auto" HeightRequest="58">
                                <Label Text="👤" FontSize="20" VerticalTextAlignment="Center" />
                                <Label Grid.Column="1" Text="Edit Profile" FontSize="20" VerticalTextAlignment="Center" />
                                <Label Grid.Column="2" Text="›" FontSize="26" TextColor="#9A9AA2" VerticalTextAlignment="Center" />
                            
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding OpenEditProfileCommand}" />
                                </Grid.GestureRecognizers></Grid>

                            <BoxView HeightRequest="1" Color="#F0F0F3" IsVisible="{Binding ShowPurchases}" />

                            <Grid ColumnDefinitions="Auto,*,Auto" HeightRequest="58" IsVisible="{Binding ShowPurchases}">
                                <Label Text="👜" FontSize="20" VerticalTextAlignment="Center" />
                                <Label Grid.Column="1" Text="Purchases" FontSize="20" VerticalTextAlignment="Center" />
                                <Label Grid.Column="2" Text="›" FontSize="26" TextColor="#9A9AA2" VerticalTextAlignment="Center" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10">
                    <Label Text="Preferences"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#0D5B6C" />

                    <Border Stroke="#ECECF1"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="White"
                            Padding="14,6">
                        <VerticalStackLayout Spacing="0">
                            <Grid ColumnDefinitions="Auto,*,Auto" HeightRequest="58">
                                <Label Text="🌐" FontSize="20" VerticalTextAlignment="Center" />
                                <Label Grid.Column="1" Text="Language" FontSize="20" VerticalTextAlignment="Center" />
                                <Label Grid.Column="2" Text="VI" FontSize="18" TextColor="#3D3D45" VerticalTextAlignment="Center" />
                            </Grid>

                            <BoxView HeightRequest="1" Color="#F0F0F3" />

                            <Grid ColumnDefinitions="Auto,*,Auto" HeightRequest="58">
                                <Label Text="⚙" FontSize="20" VerticalTextAlignment="Center" />
                                <Label Grid.Column="1" Text="User preferences" FontSize="20" VerticalTextAlignment="Center" />
                                <Label Grid.Column="2" Text="›" FontSize="26" TextColor="#9A9AA2" VerticalTextAlignment="Center" />
                            </Grid>

                            <BoxView HeightRequest="1" Color="#F0F0F3" IsVisible="{Binding ShowDownloads}" />

                            <Grid ColumnDefinitions="Auto,*,Auto" HeightRequest="58" IsVisible="{Binding ShowDownloads}">
                                <Label Text="↓" FontSize="20" VerticalTextAlignment="Center" />
                                <Label Grid.Column="1" Text="Downloads" FontSize="20" VerticalTextAlignment="Center" />
                                <Label Grid.Column="2" Text="›" FontSize="26" TextColor="#9A9AA2" VerticalTextAlignment="Center" />
                            </Grid>

                            <BoxView HeightRequest="1" Color="#F0F0F3" IsVisible="{Binding ShowBookmarks}" />

                            <Grid ColumnDefinitions="Auto,*,Auto" HeightRequest="58" IsVisible="{Binding ShowBookmarks}">
                                <Label Text="▮" FontSize="20" VerticalTextAlignment="Center" />
                                <Label Grid.Column="1" Text="Bookmarks" FontSize="20" VerticalTextAlignment="Center" />
                                <Label Grid.Column="2" Text="›" FontSize="26" TextColor="#9A9AA2" VerticalTextAlignment="Center" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <Button Text="{Binding PrimaryActionText}"
                        Command="{Binding PrimaryActionCommand}"
                        BackgroundColor="#E31667"
                        TextColor="White"
                        FontSize="21"
                        FontAttributes="Bold"
                        HeightRequest="62"
                        CornerRadius="31"
                        Margin="0,10,0,0" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>




